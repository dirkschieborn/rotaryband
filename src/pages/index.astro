---
import BaseLayout from '../layouts/BaseLayout.astro';

const reviews: any[] = [];

const members = [
  { name: 'Eckhard Burling', instruments: 'Guitar, Vocals & Ukulele', image: '/images/member-eckhard.jpg' },
  { name: 'Rainer Grosse', instruments: 'Bass & Vocals', image: '/images/member-rainer.jpg' },
  { name: 'Oliver Boese', instruments: 'Saxophone, Vocals & Percussion', image: '/images/member-oliver.jpg' },
  { name: 'Dirk Schieborn', instruments: 'Keys & Cello', image: '/images/member-dirk.jpg' },
  { name: 'Carl-Philipp Clarenbach', instruments: 'Drums & Cajón', image: '/images/member-carl.jpg' },
];

const songs = [
  'Old Time Rock\'n\'Roll',
  'Mustang Sally',
  'Long Train Running',
  'Midnight Hour',
  'The Heat Is On',
  'Everybody Needs Somebody to Love',
  'Jailhouse Rock',
  'Lay Down Sally',
];

---

<BaseLayout title="2R2B – Die Rotary Band | Musik für den guten Zweck" description="2R2B – die Rotary Remstal Besen Band. 5 Rotarier aus dem Remstal spielen Rock'n'Roll Klassiker. 100% der Gage gehen an die Kinderstiftung Funke.">

  <!-- ============ HERO ============ -->
  <section class="relative min-h-[100svh] flex flex-col overflow-hidden">
    <!-- Background Image: 70svh on mobile, full on desktop -->
    <div class="relative h-[70svh] md:absolute md:inset-0 md:h-auto">
      <img
        src="/images/rotaryband-hero.jpg"
        alt="2R2B – Die Rotary Band live"
        class="w-full h-full object-cover object-[center_60%] md:object-[center_30%]"
        style="height: 100%; max-width: none;"
      />
      <!-- Gradient bottom fade -->
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent via-60% to-[#0a0a0a] md:from-[#0a0a0a]/40 md:via-[#0a0a0a]/20 md:via-40% md:to-[#0a0a0a]"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center px-4 md:px-6 max-w-4xl mx-auto flex flex-col items-center justify-center flex-1 -mt-20 md:mt-0 md:pb-24">
      <!-- Logo -->
      <img
        src="/images/logo_weiss.png"
        alt="Rotary Band"
        class="w-48 sm:w-64 md:w-80 lg:w-[420px] mb-4 md:mb-6 opacity-0 animate-[fadeIn_1s_0.3s_forwards] drop-shadow-[0_2px_20px_rgba(0,0,0,0.5)]"
      />

      <h1 class="text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold opacity-0 animate-[fadeIn_1s_0.6s_forwards] drop-shadow-[0_2px_10px_rgba(0,0,0,0.5)]">
        Musik für den guten Zweck
      </h1>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-4 md:bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-[fadeIn_1s_1.2s_forwards]">
      <div class="w-5 h-8 md:w-6 md:h-10 border-2 border-white/30 rounded-full flex justify-center pt-1.5 md:pt-2">
        <div class="w-1 h-2.5 md:h-3 bg-white/60 rounded-full animate-bounce"></div>
      </div>
    </div>
  </section>


  <!-- ============ INTRO ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <!-- Ambilight: amber accent glow centered vertically, fades to transparent at all edges -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 75% 55%, rgba(200, 150, 40, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div data-reveal>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Aus dem Rotary Club Stuttgart-Remstal</p>
          <h2 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">Wir sind<br/><span class="text-primary-light">die Rotary Band</span></h2>
          <p class="text-white/60 text-lg leading-relaxed mb-4">
            Die Rotary Band – fünf Rotarier, die seit 2015 ihre Leidenschaft für Musik mit dem Engagement für einen guten Zweck verbinden. Wir spielen Rock'n'Roll Klassiker auf Firmenfeiern, Hochzeiten, privaten Feiern und Charity Events.
          </p>
          <p class="text-white/50 leading-relaxed mb-8">
            Das Besondere: 100% unserer Gage gehen an die Kinderstiftung Funke – eine Kinderstiftung im Rems-Murr-Kreis unter dem Dach der Caritas Stiftung Lebenswerk Zukunft. Wer uns bucht, feiert nicht nur gut, sondern tut auch Gutes.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="mailto:2r2b@dierotaryband.de" class="btn btn-outline text-sm !py-2.5 !px-5">Kontakt aufnehmen</a>
          </div>
        </div>
        <div data-reveal data-reveal-delay="2" class="relative">
          <div class="relative overflow-hidden rounded-2xl shadow-2xl">
            <img
              src="/images/rotaryband-hero.jpg"
              alt="2R2B – Die Rotary Band"
              class="w-full aspect-[16/9] object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WAS WIR BIETEN ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden ">
    <!-- Ambilight: teal/green accent, centered to avoid edge cuts -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 55% 50%, rgba(40, 180, 130, 0.18) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16" data-reveal>
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Was wir bieten</p>
        <h2 class="text-4xl md:text-5xl font-bold">Bucht uns für euer Event</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 relative z-10">
        <div class="group flex flex-col rounded-2xl overflow-hidden bg-surface-card border border-border hover:border-primary/30 transition-all duration-300" data-reveal data-reveal-delay="1">
          <div class="relative overflow-hidden">
            <img src="/images/wp/2024-08-DZ-124.8240.webp" alt="Charity Events" class="w-full aspect-[4/3] object-cover block transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#161616] to-transparent pointer-events-none"></div>
          </div>
          <div class="px-5 pb-5 pt-0 -mt-10 relative z-10 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-white mb-1">Charity Events</h3>
            <p class="text-white/50 text-sm mb-3 flex-1">Benefiz-Veranstaltungen sind unsere Herzensangelegenheit</p>
          </div>
        </div>

        <div class="group flex flex-col rounded-2xl overflow-hidden bg-surface-card border border-border hover:border-primary/30 transition-all duration-300" data-reveal data-reveal-delay="2">
          <div class="relative overflow-hidden">
            <img src="/images/wp/2025-07-Bildschirmfoto-2025-07-18-um-22.22.24.webp" alt="Firmenevents" class="w-full aspect-[4/3] object-cover block transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#161616] to-transparent pointer-events-none"></div>
          </div>
          <div class="px-5 pb-5 pt-0 -mt-10 relative z-10 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-white mb-1">Firmenevents</h3>
            <p class="text-white/50 text-sm mb-3 flex-1">Jubiläum, Kick-Off oder Weihnachtsfeier – wir sorgen für Stimmung</p>
          </div>
        </div>

        <div class="group flex flex-col rounded-2xl overflow-hidden bg-surface-card border border-border hover:border-primary/30 transition-all duration-300" data-reveal data-reveal-delay="3">
          <div class="relative overflow-hidden">
            <img src="/images/wp/2024-06-Beitragsbild.webp" alt="Private Events" class="w-full aspect-[4/3] object-cover block transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#161616] to-transparent pointer-events-none"></div>
          </div>
          <div class="px-5 pb-5 pt-0 -mt-10 relative z-10 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-white mb-1">Private Events</h3>
            <p class="text-white/50 text-sm mb-3 flex-1">Geburtstag, Jubiläum oder einfach feiern – wir sind dabei</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ UNSER GUTER ZWECK ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <!-- Ambilight: warm orange/gold accent, centered vertically -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(220, 140, 40, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center" data-reveal>
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Unser guter Zweck</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Kinderstiftung Funke</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Jeder Cent unserer Gage geht an die Kinderstiftung Funke im Rems-Murr-Kreis, eine Stiftung unter dem Dach der Caritas Stiftung Lebenswerk Zukunft. Die Stiftung setzt sich für Kinder und Jugendliche in der Region ein.
          </p>
          <p class="text-white/50 leading-relaxed mb-8">
            Seit unserer Gründung 2015 haben wir so bei zahlreichen Auftritten einen beachtlichen Betrag zusammenspielen können. Wer uns bucht, feiert nicht nur gut – sondern hilft Kindern in der Region.
          </p>
          <div class="mb-8">
            <a href="https://www.kinderstiftung-funke.de/" target="_blank" rel="noopener" class="btn btn-primary text-sm !py-2.5 !px-5">Mehr über die Kinderstiftung Funke</a>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-6">
            <div class="text-center">
              <p class="text-3xl md:text-4xl font-bold text-primary-light">13</p>
              <p class="text-white/50 text-sm mt-1">Events</p>
            </div>
            <div class="text-center">
              <p class="text-3xl md:text-4xl font-bold text-primary-light">&euro;56.000</p>
              <p class="text-white/50 text-sm mt-1">gespendet</p>
            </div>
            <div class="text-center">
              <p class="text-3xl md:text-4xl font-bold text-primary-light">5</p>
              <p class="text-white/50 text-sm mt-1">Rotarier</p>
            </div>
          </div>
        </div>
        <div>
          <img src="/images/kinderstiftung-funke.jpg" alt="Kinderstiftung Funke" class="w-full rounded-3xl shadow-2xl aspect-[16/9] object-cover object-right" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ DIE BAND ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <!-- Ambilight: soft rose/pink accent, centered vertically -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 30% 50%, rgba(200, 100, 140, 0.15) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16" data-reveal>
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Die Band</p>
        <h2 class="text-4xl md:text-5xl font-bold">5 Rotarier, 1 Mission</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 relative z-10">
        {members.slice(0, 3).map((m, i) => (
          <div
            class="bg-surface-card border border-border rounded-2xl overflow-hidden text-center hover:border-primary/30 transition-all duration-300 hover:-translate-y-1"
            data-reveal
            data-reveal-delay={String(i + 1)}
          >
            <img src={m.image} alt={m.name} class="w-full aspect-[4/3] object-cover object-top" />
            <div class="p-5">
              <h3 class="text-white font-semibold text-lg mb-1">{m.name}</h3>
              <p class="text-white/50 text-sm">{m.instruments}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6 max-w-[66%] mx-auto mt-6 relative z-10">
        {members.slice(3, 5).map((m, i) => (
          <div
            class="bg-surface-card border border-border rounded-2xl overflow-hidden text-center hover:border-primary/30 transition-all duration-300 hover:-translate-y-1"
            data-reveal
            data-reveal-delay={String(i + 1)}
          >
            <img src={m.image} alt={m.name} class="w-full aspect-[4/3] object-cover object-top" />
            <div class="p-5">
              <h3 class="text-white font-semibold text-lg mb-1">{m.name}</h3>
              <p class="text-white/50 text-sm">{m.instruments}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ REPERTOIRE ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <!-- Ambilight: green/lime accent, centered vertically -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 65% 50%, rgba(80, 200, 80, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center" data-reveal>
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Repertoire</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Rock'n'Roll Klassiker</h2>
          <p class="text-white/60 leading-relaxed mb-8">
            Wir spielen die Songs, die jeder kennt und liebt – zeitlose Rock'n'Roll Hits, die garantiert jeden auf die Tanzfläche bringen.
          </p>
        </div>
        <div>
          <div class="grid sm:grid-cols-2 gap-3">
            {songs.map((song, i) => (
              <div
                class="bg-surface-card border border-border rounded-xl px-5 py-3 hover:border-primary/30 transition-all duration-300 flex items-center gap-3"
                data-reveal
                data-reveal-delay={String(Math.min(i + 1, 3))}
              >
                <span class="text-primary-light text-lg">&#9835;</span>
                <span class="text-white/80 text-sm">{song}</span>
              </div>
            ))}
          </div>
          <p class="text-white/40 text-sm mt-4 italic">... und viele weitere Klassiker</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BUCHT UNS ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <!-- Ambilight: warm magenta accent, centered vertically -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 50% 50%, rgba(180, 50, 100, 0.18) 0%, transparent 100%);"></div>
    <div class="max-w-3xl mx-auto px-8 text-center" data-reveal>
      <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Bucht uns</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Wir spielen auf eurem Event</h2>
      <p class="text-white/60 text-lg leading-relaxed mb-4">
        Wir spielen auf Ihrer Party, Ihrer Hochzeit, Ihrer Firmenfeier... Unsere Gage ist zwar verhandelbar, kommt aber zu 100% einem guten Zweck zugute.
      </p>
      <p class="text-white/50 leading-relaxed mb-10">
        Schreibt uns einfach eine E-Mail und wir besprechen alles Weitere.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="mailto:2r2b@dierotaryband.de" class="btn btn-primary">
          2r2b@dierotaryband.de
        </a>
        <a href="https://www.instagram.com/dierotaryband" target="_blank" rel="noopener noreferrer" class="btn btn-outline text-sm !py-2.5 !px-5">
          @dierotaryband auf Instagram
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  // Scroll reveal with Intersection Observer
  const reveals = document.querySelectorAll('[data-reveal]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  reveals.forEach((el) => observer.observe(el));
</script>
