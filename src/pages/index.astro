---
import BaseLayout from '../layouts/BaseLayout.astro';

const reviews = [
  { text: 'Nur Liebe für diese Band! Auf der Bühne liefern sie alle richtig ab und egal ob 5 oder 50 oder 500 Leute drumherum stehen, sie geben jedem das Gefühl extra für dich zu spielen. 11/10 highly recommend!', author: 'Janina', date: '17.12.2025' },
  { text: 'Dropzone hat unsere Hochzeitsfeier zu etwas Besonderem gemacht. Vielen Dank für Euren reibungslosen und unkomplizierten Ablauf und für die geniale Stimmung an diesem Abend.', author: 'Friederike Kugler', date: '29.04.2025' },
  { text: 'Wir haben unser 25. Jubiläum mit Dropzone gefeiert und sind begeistert! Wir konnten uns blind auf die Band verlassen. Vielen Dank und immer gerne wieder!', author: 'Regina Faller', date: '17.10.2024' },
  { text: 'Tolle Band, phantastisches Entertainment und einfach super sympathische Bandmitglieder. Buchen mit Begeisterungsgarantie. Jederzeit gerne wieder!', author: 'David Pricking', date: '30.07.2024' },
  { text: 'Wir hatten schon 2 tolle Anlässe mit Dropzone: zur Hochzeit auf 2222 m ü.M. in der Schweiz und eine Kongressparty in Amsterdam. Auch diesmal wieder ein Volltreffer.', author: 'Nicola Zitzmann', date: '30.06.2024' },
  { text: 'Einzigartige Band mit breitem Repertoire und einer Leadsängerin, deren Stimme unter die Haut geht. Absolut empfehlenswert!', author: 'Anna Gasché', date: '11.06.2024' },
];

---

<BaseLayout title="Dropzone – die Eventband für Firmenfeiern, Hochzeiten, Festivals" description="Willkommen bei der Band Dropzone aus Stuttgart: Wir rocken Firmenfeiern, Hochzeiten, Festivals und private Feiern – mit Energie, Spielfreude und über 20 Jahren Bühnenerfahrung.">

  <!-- ============ HERO ============ -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background Video -->
    <div class="absolute inset-0">
      <video
        id="heroVideo"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster="https://www.dropzone-band.de/wp-content/uploads/2016/03/DSC_7487-1-1.jpg"
        class="w-full h-full object-cover"
      >
        <source src="https://www.dropzone-band.de/wp-content/uploads/2024/09/Dropzoneband_2024_final_v1_HD_1.mp4" type="video/mp4" />
      </video>
    </div>
    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/50 via-[#0a0a0a]/10 to-[#0a0a0a]"></div>

    <!-- Content -->
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto flex flex-col items-center">
      <!-- Logo -->
      <img
        src="/images/logo_weiss.png"
        alt="Dropzone – Die Eventband"
        class="w-64 md:w-80 lg:w-96 mb-8 opacity-0 animate-[fadeIn_1s_0.3s_forwards]"
      />

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 opacity-0 animate-[fadeIn_1s_0.6s_forwards]">
        Eventband für Firmenfeiern, Hochzeiten, Festivals.
      </h1>
      <p class="text-lg md:text-xl text-white/60 mb-10 opacity-0 animate-[fadeIn_1s_0.8s_forwards]">
        Wir rocken eure Hütte – mit Energie und Spielfreude.
      </p>

      <!-- Ton an/aus Button -->
      <button
        id="muteToggle"
        class="opacity-0 animate-[fadeIn_1s_1s_forwards] inline-flex items-center gap-2 px-6 py-2.5 border border-white/30 rounded-full text-white text-sm font-semibold hover:bg-white/10 hover:border-white/60 transition-all duration-300 cursor-pointer"
      >
        <svg id="muteIcon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <line x1="23" y1="9" x2="17" y2="15"></line>
          <line x1="17" y1="9" x2="23" y2="15"></line>
        </svg>
        <svg id="unmuteIcon" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
        </svg>
        <span id="muteLabel">Ton an</span>
      </button>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0 animate-[fadeIn_1s_1.2s_forwards]">
      <div class="w-6 h-10 border-2 border-white/30 rounded-full flex justify-center pt-2">
        <div class="w-1 h-3 bg-white/60 rounded-full animate-bounce"></div>
      </div>
    </div>
  </section>


  <!-- ============ INTRO ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <!-- Ambilight: amber accent glow centered vertically, fades to transparent at all edges -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 75% 55%, rgba(200, 150, 40, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div data-reveal>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Coverband und Eventband aus Stuttgart</p>
          <h2 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">Wir sind<br/><span class="text-primary-light">Dropzone</span></h2>
          <p class="text-white/60 text-lg leading-relaxed mb-4">
            Eure Liveband für Events jeder Art und Größe. Ob als Coverband für eine Geburtstagsfeier, Galaband für das gediegene Ambiente, Partyband für euer Firmenevent oder als Hochzeitsband – wir liefern beste Live-Musik auf Firmenevents, Privatevents und Festivalbühnen.
          </p>
          <p class="text-white/50 leading-relaxed mb-8">
            Mit erstklassigen, professionellen Musikern mit langjähriger Bühnenerfahrung bieten wir ein vielseitiges Repertoire und schaffen seit über zwanzig Jahren unvergessliche Livemusik-Momente. Dazu passende Veranstaltungstechnik, DJ-Service und professionelles Eventmanagement – alles aus einer Hand.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/wer-wir-sind/" class="btn btn-outline text-sm !py-2.5 !px-5">Die Band kennenlernen</a>
          </div>
        </div>
        <div data-reveal data-reveal-delay="2" class="relative">
          <!-- Image Carousel -->
          <div class="relative overflow-hidden rounded-2xl shadow-2xl cursor-zoom-in" id="introCarousel">
            <div class="flex transition-transform duration-700 ease-out" id="introTrack">
              {[
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2016/03/234.jpg', alt: 'Dropzone – Coverband live auf der Bühne' },
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/08/DZ-136.8300.jpg', alt: 'Dropzone Sänger auf der Bühne' },
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/DZ.136.7344-scaled.jpg', alt: 'Dropzone Liveband Performance' },
              ].map((img) => (
                <div class="w-full flex-shrink-0">
                  <img
                    src={img.src}
                    alt={img.alt}
                    class="w-full aspect-[16/9] object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
            <!-- Nav Arrows -->
            <button id="introPrev" class="absolute top-1/2 left-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Vorheriges Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button id="introNext" class="absolute top-1/2 right-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Nächstes Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
          {/* Thumbs */}
          <div class="flex gap-2 mt-3" id="introThumbs">
            {[
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2016/03/234.jpg', alt: 'Dropzone – Coverband live auf der Bühne' },
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/08/DZ-136.8300.jpg', alt: 'Dropzone Sänger auf der Bühne' },
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/DZ.136.7344-scaled.jpg', alt: 'Dropzone Liveband Performance' },
            ].map((img, i) => (
              <button class={`flex-1 rounded-lg overflow-hidden border-2 transition-all duration-300 cursor-pointer ${i === 0 ? 'border-primary' : 'border-transparent opacity-50 hover:opacity-80'}`} data-thumb={i}>
                <img src={img.src} alt={img.alt} class="w-full aspect-[16/9] object-cover" loading="lazy" />
              </button>
            ))}
          </div>
          {/* Lightbox */}
          <div id="introLightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black">
            <button id="introLbClose" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Schließen">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
            <button id="introLbPrev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Zurück">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button id="introLbNext" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Weiter">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <img id="introLbImage" src="" alt="" class="max-w-[95vw] max-h-[95vh] object-contain" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ EVENTS ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden ">
    <!-- Ambilight: teal/green accent, centered to avoid edge cuts -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 55% 50%, rgba(40, 180, 130, 0.18) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16" data-reveal>
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Was wir machen</p>
        <h2 class="text-4xl md:text-5xl font-bold">Euer Event, unser Sound</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 relative z-10">
        <a href="/events/hochzeiten/" class="group flex flex-col rounded-2xl overflow-hidden bg-surface-card border border-border hover:border-primary/30 transition-all duration-300" data-reveal data-reveal-delay="1">
          <div class="relative overflow-hidden">
            <img src="https://www.dropzone-band.de/wp-content/uploads/2016/03/DSC_7487-1-1.jpg" alt="Hochzeiten" class="w-full aspect-[4/3] object-cover block transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#161616] to-transparent pointer-events-none"></div>
          </div>
          <div class="px-5 pb-5 pt-0 -mt-10 relative z-10 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-white mb-1">Hochzeiten</h3>
            <p class="text-white/50 text-sm mb-3 flex-1">Eure Hochzeitsband mit Stil, Eleganz und jeder Menge guter Musik</p>
            <span class="text-primary-light text-sm font-semibold group-hover:translate-x-1 transition-transform inline-block">Mehr erfahren →</span>
          </div>
        </a>

        <a href="/events/firmenevents/" class="group flex flex-col rounded-2xl overflow-hidden bg-surface-card border border-border hover:border-primary/30 transition-all duration-300" data-reveal data-reveal-delay="2">
          <div class="relative overflow-hidden">
            <img src="https://www.dropzone-band.de/wp-content/uploads/2025/07/Bildschirmfoto-2025-07-18-um-22.22.24.jpg" alt="Firmenevents" class="w-full aspect-[4/3] object-cover block transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#161616] to-transparent pointer-events-none"></div>
          </div>
          <div class="px-5 pb-5 pt-0 -mt-10 relative z-10 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-white mb-1">Firmenevents</h3>
            <p class="text-white/50 text-sm mb-3 flex-1">Jubiläum, Kick-Off, Weihnachtsfeier – maßgeschneidert mit Rundum-Sorglos-Paket</p>
            <span class="text-primary-light text-sm font-semibold group-hover:translate-x-1 transition-transform inline-block">Mehr erfahren →</span>
          </div>
        </a>

        <a href="/events/festivals/" class="group flex flex-col rounded-2xl overflow-hidden bg-surface-card border border-border hover:border-primary/30 transition-all duration-300" data-reveal data-reveal-delay="3">
          <div class="relative overflow-hidden">
            <img src="https://www.dropzone-band.de/wp-content/uploads/2024/08/DZ-124.8240.jpg" alt="Festivals" class="w-full aspect-[4/3] object-cover block transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#161616] to-transparent pointer-events-none"></div>
          </div>
          <div class="px-5 pb-5 pt-0 -mt-10 relative z-10 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-white mb-1">Festivals &amp; Stadtfeste</h3>
            <p class="text-white/50 text-sm mb-3 flex-1">Energiegeladene Auftritte auf Stadtfesten, Open Airs und Festivals</p>
            <span class="text-primary-light text-sm font-semibold group-hover:translate-x-1 transition-transform inline-block">Mehr erfahren →</span>
          </div>
        </a>

        <a href="/events/private/" class="group flex flex-col rounded-2xl overflow-hidden bg-surface-card border border-border hover:border-primary/30 transition-all duration-300" data-reveal data-reveal-delay="4">
          <div class="relative overflow-hidden">
            <img src="https://www.dropzone-band.de/wp-content/uploads/2024/06/Beitragsbild.jpg" alt="Private Events" class="w-full aspect-[4/3] object-cover block transition-transform duration-700 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#161616] to-transparent pointer-events-none"></div>
          </div>
          <div class="px-5 pb-5 pt-0 -mt-10 relative z-10 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-white mb-1">Private Feiern</h3>
            <p class="text-white/50 text-sm mb-3 flex-1">Geburtstag, Jubiläum oder einfach feiern – wir machen's unvergesslich</p>
            <span class="text-primary-light text-sm font-semibold group-hover:translate-x-1 transition-transform inline-block">Mehr erfahren →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ FIRMENEVENTS DETAIL ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <!-- Ambilight: warm orange/gold accent from stage lighting, centered vertically -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(220, 140, 40, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center" data-reveal>
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Firmenevents</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Get boosted!</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Feiert euren Erfolg beim Firmenjubiläum, startet mit Schwung gemeinsam in ein neues Geschäftsjahr beim Kick-Off-Event oder lasst das Jahr ausklingen bei der Weihnachtsfeier – Dropzone liefert den maßgeschneiderten Live-Soundtrack für jeden Anlass.
          </p>
          <p class="text-white/50 leading-relaxed mb-6">
            Mit passenden Rundum-Sorglos-Paketen inklusive professioneller Licht- und Soundtechnik und einem vielseitigen Repertoire schaffen wir unvergessliche Momente für eure Firmenevents.
          </p>
          <a href="/events/firmenevents/" class="btn btn-outline text-sm !py-2.5 !px-5">Mehr Infos</a>
        </div>
        <div>
          <img src="https://www.dropzone-band.de/wp-content/uploads/2023/11/test-1.jpg" alt="Dropzone live auf einem Firmenevent" class="w-full rounded-3xl shadow-2xl aspect-[16/9] object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ HOCHZEITEN DETAIL ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <!-- Ambilight: soft rose/pink accent from warm wedding ambiance, centered vertically -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 30% 50%, rgba(200, 100, 140, 0.15) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[3fr_2fr] gap-12 md:gap-16 items-center" data-reveal>
        <div>
          <img src="https://www.dropzone-band.de/wp-content/uploads/2016/03/DSC_7487-1-1.jpg" alt="Dropzone als Hochzeitsband" class="w-full rounded-3xl shadow-2xl aspect-[16/9] object-cover" loading="lazy" />
        </div>
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Privatevents</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Eure Hochzeitsband</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Wir sind eure Hochzeitsband! Lasst uns gemeinsam die perfekten musikalischen Vibes für euren besonderen Tag kreieren – mit Stil, Eleganz und jeder Menge guter Musik. Mit mehr als zwanzig Jahren Erfahrung machen wir eure Hochzeits- oder Geburtstagsfeier unvergesslich.
          </p>
          <p class="text-white/50 leading-relaxed mb-6">
            Dabei sorgen wir durch mitgelieferte Licht- und Soundtechnik dafür, dass alles reibungsfrei abläuft und ihr euren Tag und eure Hochzeitsband entspannt genießen könnt.
          </p>
          <a href="/events/hochzeiten/" class="btn btn-outline text-sm !py-2.5 !px-5">Mehr Infos</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ FESTIVALS DETAIL ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <!-- Ambilight: green/lime accent from festival stage lighting, centered vertically -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 65% 50%, rgba(80, 200, 80, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center" data-reveal>
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Festivals und Stadtfeste</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">Let's rock!</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Dropzone ist der Garant für energiegeladene Auftritte auf Stadtfesten, Open Airs und Festivals! Mit einem mitreißenden Repertoire und dynamischer Bühnenpräsenz bringen wir jede Veranstaltung zum Beben.
          </p>
          <p class="text-white/50 leading-relaxed mb-6">
            Bucht uns für mitreißende Momente als perfekten musikalischen Act für euer nächstes Stadtfest, Open Air oder Festival – Let's rock the crowd together!
          </p>
          <a href="/events/festivals/" class="btn btn-outline text-sm !py-2.5 !px-5">Mehr Infos</a>
        </div>
        <div>
          <img src="https://www.dropzone-band.de/wp-content/uploads/2024/02/DZ.001.6293-scaled.jpg" alt="Dropzone live auf einem Stadtfest – Fachwerkhäuser und Publikum" class="w-full rounded-3xl shadow-2xl aspect-[16/9] object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ VIDEO ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden ">
    <!-- Ambilight: warm magenta accent, centered vertically -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 30% 50%, rgba(180, 50, 100, 0.18) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-12" data-reveal>
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Live erleben</p>
        <h2 class="text-4xl md:text-5xl font-bold">Seht selbst.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6" data-reveal>
        <div class="group">
          <div class="video-wrapper !rounded-2xl shadow-xl overflow-hidden">
            <iframe src="https://www.youtube.com/embed/Ju_I95kOqxU" title="Dropzone Showreel Partyband" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <p class="mt-3 text-white font-semibold text-sm font-[Rubik]">Showreel Partyband</p>
        </div>
        <div class="group">
          <div class="video-wrapper !rounded-2xl shadow-xl overflow-hidden">
            <iframe src="https://www.youtube.com/embed/ctPncWWIwvU" title="Dropzone Showreel Firmenevent" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
          <p class="mt-3 text-white font-semibold text-sm font-[Rubik]">Showreel Firmenevent</p>
        </div>
        <div class="group">
          <div class="video-wrapper !rounded-2xl shadow-xl overflow-hidden">
            <iframe src="https://www.youtube.com/embed/FHQzYjMm2VQ" title="Dropzone Showreel Festivals" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
