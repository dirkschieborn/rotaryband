  <!-- ============ REFERENZEN ============ -->
  <section class="py-20 md:py-28 bg-surface relative overflow-hidden ">
    <!-- Ambilight: warm teal accent, centered vertically -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 70% 50%, rgba(40, 160, 150, 0.16) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-14" data-reveal>
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Referenzen</p>
        <h2 class="text-4xl md:text-5xl font-bold">Vertrauen uns</h2>
      </div>

      <!-- Carousel -->
      <div class="relative" data-reveal>
        <div class="overflow-hidden" id="refCarousel">
          <div class="flex transition-transform duration-500 ease-out" id="refTrack">
            {[
              { text: 'Es ist euch gelungen, einen maßgeschneiderten Mix aus stilvoller Loungemusik und tanzbaren Partygrooves zu schaffen, der – gepaart mit der unterhaltsamen und gewitzten Moderation eures Frontmanns Jean-Pierre – zu dem vollen Erfolg der Veranstaltung maßgeblich beigetragen hat.', logo: '/images/logos/bayernlb.png', company: 'Bayern LB', type: 'Firmenevent' },
              { text: 'Für Veranstalter ist Dropzone das perfekte Rundum-Sorglos-Paket: Sie buchen, die spielen, das Publikum hat Spaß.', logo: '/images/logos/motorpresse.jpg', company: 'Motor Presse Stuttgart', type: 'Firmenfeier' },
              { text: 'WOW!!! Wie ihr es, nahezu mühelos, geschafft habt, die ca. 900 Gäste auf die Beine und die Tanzfläche zu bewegen, verdient großen Applaus, den ihr natürlich auch schon während unserer Veranstaltung immer wieder bekommen habt.', logo: '/images/logos/nintendo.jpg', company: 'Nintendo Europe GmbH', type: 'Firmenevent', logoZoom: true },
              { text: 'Die Professionalität, mit der ihr die Anforderungen zu Musikauswahl und Logistik erfüllt habt, hat mich sehr beeindruckt. Das Können und das Engagement jedes Bandmitglieds sowie das breitgefächerte Repertoire waren die Garanten für einen gelungenen Abend.', logo: '/images/logos/telekom-round.jpg', company: 'Deutsche Telekom', type: 'Firmenevent', logoZoom: true },
              { text: 'Wir möchten uns auf diesem Weg ganz herzlich bei euch für die professionelle Zusammenarbeit und für die sehr gelungene musikalische Untermalung an diesem Abend bedanken.', logo: '/images/logos/messe-stuttgart.jpg', company: 'Landesmesse Stuttgart GmbH', type: 'Jubiläumsfeier', logoZoom: true },
              { text: 'Zu Beginn wurde das Gala-Dinner wunderbar durch die Band im richtigen Stil und Charme untermalt und zu späterem Zeitpunkt hatten wir alle gemeinsam eine tolle Party!', logo: '/images/logos/biosthetique.jpg', company: 'Laboratoire Biosthétique Kosmetik GmbH & Co', type: 'Firmenevent' },
              { text: 'Ob zu Anfang etwas mehr Power, zum Abendessen dezente Hintergrundmusik oder später für die Tanzbegeisterten unter unseren Gästen – ihr habt immer den richtigen Ton getroffen.', logo: '/images/logos/mercedes-benz.jpg', company: 'Mercedes-Benz', type: 'Firmenevent' },
              { text: 'Nochmals vielen herzlichen Dank für den fantastischen Auftritt auf den CHIP FOTO AWARDS. Ihr habt für eine top Stimmung im Saal gesorgt und unsere Gäste bestens unterhalten.', logo: '/images/logos/chip.jpg', company: 'CHIP Communications GmbH', type: 'Firmenevent' },
              { text: 'Euer professioneller Auftritt und die tolle Stimmung, die ihr erzeugt habt, haben einen wesentlichen Teil zum Gelingen des Fests beigetragen. Ihr habt wirklich gerockt!', logo: '/images/logos/mhp.png', company: 'MHP Management- und IT-Beratung', type: 'Firmenevent' },
            ].map((item) => (
              <div class="ref-slide flex-shrink-0 px-3"
                <div class="bg-surface-card border border-border rounded-2xl p-6 md:p-8 flex flex-col h-full">
                  <div class="flex items-center gap-4 pb-5 mb-5 border-b border-border">
                    <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center flex-shrink-0 overflow-hidden">
                      <img src={item.logo} alt={item.company} class:list={[item.logoZoom ? 'w-full h-full object-cover' : 'w-10 h-10 object-contain']} />
                    </div>
                    <div>
                      <p class="text-white font-semibold text-sm">{item.company}</p>
                      <p class="text-muted text-xs">{item.type}</p>
                    </div>
                  </div>
                  <svg class="w-8 h-8 text-primary/40 mb-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                  <p class="text-white/70 italic leading-relaxed flex-1">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Navigation Arrows -->
        <button id="refPrev" class="absolute top-1/2 -left-5 -translate-y-1/2 w-10 h-10 rounded-full bg-surface-card border border-border flex items-center justify-center text-white/60 hover:text-white hover:border-primary/50 transition-all z-10 cursor-pointer hidden md:flex" aria-label="Zurück">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button id="refNext" class="absolute top-1/2 -right-5 -translate-y-1/2 w-10 h-10 rounded-full bg-surface-card border border-border flex items-center justify-center text-white/60 hover:text-white hover:border-primary/50 transition-all z-10 cursor-pointer hidden md:flex" aria-label="Weiter">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        <!-- Dots -->
        <div class="flex justify-center gap-2 mt-8" id="refDots"></div>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .ref-slide {
    width: calc(100% / 3);
  }

  @media (max-width: 1024px) {
    .ref-slide {
      width: calc(100% / 2);
    }
  }

  @media (max-width: 640px) {
    .ref-slide {
      width: 100%;
    }
  }
</style>

<script>
  // Scroll reveal with Intersection Observer
  const reveals = document.querySelectorAll('[data-reveal]');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
  );
  reveals.forEach((el) => observer.observe(el));

  // Hero video mute/unmute toggle
  const heroVideo = document.getElementById('heroVideo') as HTMLVideoElement;
  const muteToggle = document.getElementById('muteToggle');
  const muteIcon = document.getElementById('muteIcon');
  const unmuteIcon = document.getElementById('unmuteIcon');
  const muteLabel = document.getElementById('muteLabel');

  muteToggle?.addEventListener('click', () => {
    if (heroVideo) {
      heroVideo.muted = !heroVideo.muted;
      if (heroVideo.muted) {
        muteIcon?.classList.remove('hidden');
        unmuteIcon?.classList.add('hidden');
        if (muteLabel) muteLabel.textContent = 'Ton an';
      } else {
        muteIcon?.classList.add('hidden');
        unmuteIcon?.classList.remove('hidden');
        if (muteLabel) muteLabel.textContent = 'Ton aus';
      }
    }
  });

  // Referenzen Carousel
  (() => {
    const track = document.getElementById('refTrack');
    const prevBtn = document.getElementById('refPrev');
    const nextBtn = document.getElementById('refNext');
    const dotsContainer = document.getElementById('refDots');
    if (!track || !dotsContainer) return;

    const totalSlides = track.children.length;
    const perView = () => window.innerWidth < 640 ? 1 : window.innerWidth < 1024 ? 2 : 3;
    let current = 0; // index of the "active" card (highlighted dot)

    function maxOffset() {
      return Math.max(0, totalSlides - perView());
    }

    // The track offset ensures the active card is visible
    function trackOffset() {
      return Math.min(current, maxOffset());
    }

    function updateCarousel() {
      const slideWidth = 100 / perView();
      const pct = trackOffset() * slideWidth;
      track.style.transform = `translateX(-${pct}%)`;
      updateDots();
      if (prevBtn) prevBtn.style.opacity = current === 0 ? '0.3' : '1';
      if (nextBtn) nextBtn.style.opacity = current >= maxOffset() ? '0.3' : '1';
    }

    function buildDots() {
      dotsContainer.innerHTML = '';
      const numDots = maxOffset() + 1;
      for (let i = 0; i < numDots; i++) {
        const dot = document.createElement('button');
        dot.className = 'w-2 h-2 rounded-full transition-all duration-300 cursor-pointer';
        dot.setAttribute('aria-label', `Karte ${i + 1}`);
        dot.addEventListener('click', () => { current = i; updateCarousel(); });
        dotsContainer.appendChild(dot);
      }
      updateDots();
    }

    function updateDots() {
      const dots = dotsContainer.children;
      for (let i = 0; i < dots.length; i++) {
        (dots[i] as HTMLElement).className = i === current
          ? 'w-6 h-2 rounded-full bg-primary-light transition-all duration-300 cursor-pointer'
          : 'w-2 h-2 rounded-full bg-white/20 transition-all duration-300 cursor-pointer';
      }
    }

    prevBtn?.addEventListener('click', () => {
      if (current > 0) { current--; updateCarousel(); }
    });

    nextBtn?.addEventListener('click', () => {
      if (current < maxOffset()) { current++; updateCarousel(); }
    });

    // Touch/swipe support
    let startX = 0;
    let isDragging = false;
    track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; isDragging = true; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        if (diff > 0 && current < maxOffset()) current++;
        else if (diff < 0 && current > 0) current--;
        updateCarousel();
      }
      isDragging = false;
    });

    buildDots();
    updateCarousel();
    window.addEventListener('resize', () => { current = Math.min(current, maxOffset()); buildDots(); updateCarousel(); });
  })();

  // Intro Carousel with Thumbs + Lightbox
  (() => {
    const track = document.getElementById('introTrack');
    const carousel = document.getElementById('introCarousel');
    const prevBtn = document.getElementById('introPrev');
    const nextBtn = document.getElementById('introNext');
    const thumbsContainer = document.getElementById('introThumbs');
    if (!track || !thumbsContainer) return;

    const total = track.children.length;
    const thumbs = thumbsContainer.querySelectorAll('button');
    let pos = 0;
    let autoTimer: ReturnType<typeof setInterval>;

    const images = Array.from(track.querySelectorAll('img')).map(img => ({
      src: (img as HTMLImageElement).src,
      alt: (img as HTMLImageElement).alt,
    }));

    function go(i: number) {
      pos = ((i % total) + total) % total;
      track.style.transform = `translateX(-${pos * 100}%)`;
      updateThumbs();
    }

    function updateThumbs() {
      thumbs.forEach((t, i) => {
        if (i === pos) {
          t.classList.add('border-primary');
          t.classList.remove('border-transparent', 'opacity-50');
        } else {
          t.classList.remove('border-primary');
          t.classList.add('border-transparent', 'opacity-50');
        }
      });
    }

    thumbs.forEach(t => {
      t.addEventListener('click', () => {
        go(Number(t.getAttribute('data-thumb')));
        resetAuto();
      });
    });

    prevBtn?.addEventListener('click', () => { go(pos - 1); resetAuto(); });
    nextBtn?.addEventListener('click', () => { go(pos + 1); resetAuto(); });

    let sx = 0;
    track.addEventListener('touchstart', (e) => { sx = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      const diff = sx - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) { go(pos + (diff > 0 ? 1 : -1)); resetAuto(); }
    });

    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => go(pos + 1), 5000);
    }

    go(0);
    resetAuto();

    // Lightbox
    const lb = document.getElementById('introLightbox');
    const lbImg = document.getElementById('introLbImage') as HTMLImageElement;
    const lbClose = document.getElementById('introLbClose');
    const lbPrev = document.getElementById('introLbPrev');
    const lbNext = document.getElementById('introLbNext');
    if (!lb || !lbImg) return;

    let lbPos = 0;

    function lbShow(i: number) {
      lbPos = ((i % total) + total) % total;
      lbImg.src = images[lbPos].src;
      lbImg.alt = images[lbPos].alt;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function lbHide() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    }

    carousel?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('button')) return;
      lbShow(pos);
    });

    lbClose?.addEventListener('click', lbHide);
    lbPrev?.addEventListener('click', () => lbShow(lbPos - 1));
    lbNext?.addEventListener('click', () => lbShow(lbPos + 1));

    lb.addEventListener('click', (e) => {
      if (e.target === lb) lbHide();
    });

    document.addEventListener('keydown', (e) => {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') lbHide();
      if (e.key === 'ArrowLeft') lbShow(lbPos - 1);
      if (e.key === 'ArrowRight') lbShow(lbPos + 1);
    });
  })();
</script>
