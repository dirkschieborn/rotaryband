---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Coverband aus Stuttgart"
  description="Dropzone – eure Coverband aus Stuttgart für Hochzeiten, Firmenevents, Festivals und private Feiern. Professionelle Live-Musik mit über 20 Jahren Erfahrung."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Coverband aus Stuttgart – Dropzone',
    description: 'Professionelle Coverband aus Stuttgart für Events jeder Art und Größe.',
    provider: { '@id': 'https://www.dropzone-band.de/#organization' },
    areaServed: { '@type': 'City', name: 'Stuttgart' },
    serviceType: 'Coverband',
  }}
>

  <Hero
    title="Wir rocken den Kessel"
    subtitle="Coverband aus Stuttgart für Events jeder Art und Größe."
    backgroundImage="/images/wp/2024-02-DZ.177.6589-scaled.webp"
    cta={{ label: 'Jetzt anfragen', href: '/booking/' }}
    ctaSecondary={{ label: 'Videos ansehen', href: '/videos/' }}
  />

  <section class="section">
    <div class="container">
      <div class="content-grid">
        <div>
          <h2 class="section-title" style="text-align:left;">Coverband aus Stuttgart</h2>
          <p>
            Dropzone ist eure erfahrene Coverband aus Stuttgart. Seit über 20 Jahren
            liefern wir beste Live-Musik auf Hochzeiten, Firmenevents, Festivals und
            privaten Feiern – in Stuttgart, Baden-Württemberg und darüber hinaus.
          </p>
          <p>
            Unser Repertoire umfasst die besten Songs aus Rock, Pop, Soul, Funk und
            aktuellen Charts. Von Ed Sheeran über Coldplay bis zu Bruno Mars und
            den größten Klassikern – wir spielen die Songs, die eure Gäste lieben.
          </p>
          <p>
            Als Rundum-Sorglos-Paket bieten wir professionelle Licht- und Tontechnik,
            DJ-Service und auf Wunsch Zusatz-Acts wie Saxophon, Bläsersektion oder
            Special Guests.
          </p>
        </div>
        <div>
          <img
            src="/images/wp/2024-02-DZ.177.6589-scaled.webp"
            alt="Dropzone – Coverband aus Stuttgart live"
            class="rounded-image"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <h2 class="section-title">Warum Dropzone?</h2>
      <div class="divider"></div>
      <div class="features-grid">
        <div class="feature-card">
          <h3>Vielseitig</h3>
          <p>Von der eleganten Gala bis zum ausgelassenen Festival – wir passen uns jedem Event perfekt an.</p>
        </div>
        <div class="feature-card">
          <h3>Professionell</h3>
          <p>Erstklassige Musiker mit langjähriger Bühnenerfahrung. Zuverlässig, pünktlich, unkompliziert.</p>
        </div>
        <div class="feature-card">
          <h3>Flexibel</h3>
          <p>Vom Duo bis zur Großbesetzung mit Bläsern – wir stellen die perfekte Formation für euer Event zusammen.</p>
        </div>
        <div class="feature-card">
          <h3>Referenzen</h3>
          <p>Mercedes-Benz, Telekom, Nintendo, Europapark – namhafte Kunden vertrauen auf unsere Qualität.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">Für jeden Anlass</h2>
      <div class="divider"></div>
      <div class="occasions-grid">
        <a href="/die-band-fur-eure-hochzeit/" class="occasion-card">
          <h3>Hochzeiten</h3>
          <p>Der perfekte Soundtrack für euren großen Tag</p>
        </a>
        <a href="/firmenevents/" class="occasion-card">
          <h3>Firmenevents</h3>
          <p>Kick-Off, Jubiläum, Weihnachtsfeier</p>
        </a>
        <a href="/festivals/" class="occasion-card">
          <h3>Festivals</h3>
          <p>Volle Energie auf großen Bühnen</p>
        </a>
        <a href="/events/private/" class="occasion-card">
          <h3>Private Feiern</h3>
          <p>Geburtstag, Jubiläum, einfach feiern</p>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .rounded-image {
    width: 100%;
    border-radius: var(--radius-xl);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  .section-dark { background: var(--color-surface-elevated); }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .feature-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.5rem;
  }

  .feature-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; }
  .feature-card p { font-size: 0.88rem; color: var(--color-muted); line-height: 1.5; }

  .occasions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .occasion-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.5rem;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .occasion-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-3px);
  }

  .occasion-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.3rem; color: #fff; }
  .occasion-card p { font-size: 0.85rem; color: var(--color-muted); margin: 0; }

  p { color: var(--color-muted); line-height: 1.7; margin-bottom: 1rem; }

  @media (max-width: 900px) {
    .content-grid { grid-template-columns: 1fr; }
    .features-grid, .occasions-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 500px) {
    .features-grid, .occasions-grid { grid-template-columns: 1fr; }
  }
</style>
