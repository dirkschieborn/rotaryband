---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Dropzone Booking & Kontakt',
  description: 'Bucht Dropzone für euer Event – Hochzeit, Firmenevent, Festival oder private Feier.',
  url: 'https://www.dropzone-band.de/booking/',
  mainEntity: {
    '@id': 'https://www.dropzone-band.de/#organization',
  },
};
---

<BaseLayout title="Booking" description="Bucht Dropzone für euer Event – Hochzeit, Firmenevent, Festival oder private Feier." schema={contactSchema}>

  <Hero
    title="Booking"
    subtitle="Haben wir dein Interesse geweckt? Lass von dir hören!"
    backgroundImage="/images/wp/2016-03-jeanpierre-mit-mikro-1.webp"
  />

  <section class="section">
    <div class="container">
      <div class="booking-grid">
        <div class="booking-form-wrap">
          <h2>Anfrage senden</h2>
          <p class="form-intro">
            Am einfachsten ist es, wenn du das Kontaktformular unten verwendest.
            Natürlich kannst du uns auch eine Mail schreiben oder uns telefonisch kontaktieren.
          </p>

          <div id="success-message" class="success-message" style="display:none;">
            Vielen Dank für eure Anfrage! Wir melden uns so schnell wie möglich bei euch.
          </div>

          <form class="booking-form" id="bookingForm">
            <div class="form-row">
              <div class="form-group">
                <label for="name">Name *</label>
                <input type="text" id="name" name="name" required placeholder="Euer Name" />
              </div>
              <div class="form-group">
                <label for="email">E-Mail *</label>
                <input type="email" id="email" name="email" required placeholder="email@beispiel.de" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="phone">Telefon</label>
                <input type="tel" id="phone" name="phone" placeholder="Eure Telefonnummer" />
              </div>
              <div class="form-group">
                <label for="date">Wunschtermin *</label>
                <input type="hidden" id="date" name="date" required />
                <div class="datepicker-wrap">
                  <button type="button" class="datepicker-trigger" id="datepickerTrigger">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span id="datepickerLabel">Datum wählen</span>
                  </button>
                  <div class="datepicker-dropdown" id="datepickerDropdown">
                    <div class="dp-header">
                      <button type="button" class="dp-nav" id="dpPrev">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                      </button>
                      <span class="dp-month-year" id="dpMonthYear"></span>
                      <button type="button" class="dp-nav" id="dpNext">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                      </button>
                    </div>
                    <div class="dp-weekdays">
                      <span>Mo</span><span>Di</span><span>Mi</span><span>Do</span><span>Fr</span><span>Sa</span><span>So</span>
                    </div>
                    <div class="dp-days" id="dpDays"></div>
                  </div>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label>Art des Events *</label>
              <div class="event-type-grid">
                <label class="event-type-option">
                  <input type="radio" name="eventType" value="hochzeit" required />
                  <span class="event-type-card">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                    Hochzeit
                  </span>
                </label>
                <label class="event-type-option">
                  <input type="radio" name="eventType" value="firmenevent" required />
                  <span class="event-type-card">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
                    Firmenevent
                  </span>
                </label>
                <label class="event-type-option">
                  <input type="radio" name="eventType" value="festival" required />
                  <span class="event-type-card">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                    Festival / Stadtfest
                  </span>
                </label>
                <label class="event-type-option">
                  <input type="radio" name="eventType" value="privat" required />
                  <span class="event-type-card">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                    Private Feier
                  </span>
                </label>
                <label class="event-type-option">
                  <input type="radio" name="eventType" value="sonstiges" required />
                  <span class="event-type-card">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
                    Sonstiges
                  </span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label for="location">Location / Ort</label>
              <input type="text" id="location" name="location" placeholder="Ort / Venue" />
            </div>

            <div class="form-group">
              <label for="guests">Anzahl Gäste (ca.)</label>
              <input type="number" id="guests" name="guests" placeholder="z.B. 100" />
            </div>

            <div class="form-group">
              <label for="message">Eure Nachricht *</label>
              <textarea id="message" name="message" rows="5" required placeholder="Erzählt uns von eurem Event..."></textarea>
            </div>

            <label class="proberaum-option">
              <input type="checkbox" name="proberaum" value="ja" />
              <span class="proberaum-card">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Ich habe Interesse, euch bei einem Proberaumkonzert kennenzulernen.
              </span>
            </label>

            <div class="form-group">
              <label class="checkbox-label">
                <input type="checkbox" name="privacy" required />
                <span>Ich habe die <a href="/datenschutz/">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zu. *</span>
              </label>
            </div>

            <button type="submit" class="btn btn-primary btn-large">Anfrage absenden</button>
          </form>
        </div>

        <aside class="booking-sidebar">
          <div class="sidebar-card card">
            <div class="card-body">
              <h3>Schnell-Kontakt</h3>
              <ul class="contact-list">
                <li>
                  <a href="tel:+497113406789500" class="contact-row">
                    <span class="contact-icon contact-icon--phone">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                    </span>
                    0711 340 6789 500
                  </a>
                </li>
                <li>
                  <a href="mailto:info@dropzone-band.de" class="contact-row">
                    <span class="contact-icon contact-icon--mail">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </span>
                    info@dropzone-band.de
                  </a>
                </li>
                <li>
                  <a href="https://wa.me/491703055587" target="_blank" rel="noopener" class="contact-row">
                    <span class="contact-icon contact-icon--whatsapp">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    </span>
                    0170 30 555 87
                  </a>
                </li>
              </ul>
            </div>
          </div>

          <div class="sidebar-card card">
            <div class="card-body">
              <h3>Gut zu wissen</h3>
              <ul class="info-list">
                <li>Wir spielen deutschlandweit & international</li>
                <li>Eigene PA- & Lichttechnik vorhanden</li>
                <li>Flexible Besetzung von Duo bis Full-Band</li>
                <li>DJ-Service auf Wunsch inklusive</li>
                <li>Persönliche Beratung vor jedem Event</li>
              </ul>
            </div>
          </div>

          <div class="sidebar-card card">
            <div class="card-body">
              <h3>Kostenrechner</h3>
              <p class="sidebar-text">Erhaltet eine erste Preiseinschätzung für euer Event.</p>
              <a href="/kostenrechner/" class="btn btn-outline" style="width:100%;justify-content:center;">Zum Kostenrechner</a>
            </div>
          </div>

          <!-- Proberaumkonzert -->
          <div class="sidebar-card card">
            <div class="card-body" style="padding:0;">
              <div class="video-wrapper" style="border-radius:var(--radius-lg) var(--radius-lg) 0 0;">
                <iframe src="https://www.youtube-nocookie.com/embed/fhMyjYlfbIM" title="Proberaumkonzert für unsere Brautpaare" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
              </div>
              <div style="padding:1.25rem;">
                <h3 style="font-size:1.1rem;margin-bottom:0.6rem;">Proberaumkonzert</h3>
                <p class="sidebar-text">Lernt uns persönlich kennen! In entspannter Atmosphäre spielen wir ein paar Songs für euch und beantworten alle eure Fragen. Völlig unverbindlich.</p>
                <a href="/die-band-fur-eure-hochzeit/#proberaumkonzert" class="btn btn-outline" style="width:100%;justify-content:center;">Nächster Termin</a>
              </div>
            </div>
          </div>

        </aside>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .booking-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }

  .booking-form-wrap h2 { margin-bottom: 0.5rem; }
  .form-intro { color: var(--color-text-muted); margin-bottom: 2rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { margin-bottom: 1.25rem; }

  .form-group label {
    display: block; font-size: 0.9rem; font-weight: 600;
    color: var(--color-text); margin-bottom: 0.4rem;
  }

  .form-group input:not([type="checkbox"]):not([type="radio"]):not([type="hidden"]),
  .form-group select,
  .form-group textarea {
    width: 100%; padding: 0.75rem 1rem; background: var(--color-bg-card);
    border: 1px solid #444; border-radius: var(--radius-md);
    color: var(--color-text); font-family: var(--font-body); font-size: 0.95rem;
    transition: border-color var(--transition-fast);
  }

  /* Event-Type Radio Buttons */
  .event-type-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.6rem;
  }
  .event-type-option { cursor: pointer; }
  .event-type-option input { position: absolute; opacity: 0; pointer-events: none; }
  .event-type-card {
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    padding: 0.9rem 0.5rem; border-radius: var(--radius-md);
    border: 1px solid var(--color-border); background: var(--color-bg-card);
    color: var(--color-text-muted); font-size: 0.8rem; font-weight: 600;
    text-align: center; transition: all 0.2s ease;
  }
  .event-type-card:hover { border-color: var(--color-primary); color: var(--color-text); }
  .event-type-option input:checked + .event-type-card {
    border-color: var(--color-primary); background: rgba(172, 72, 57, 0.12);
    color: var(--color-primary-light);
  }
  @media (max-width: 640px) {
    .event-type-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .proberaum-option { cursor: pointer; display: block; margin-bottom: 1.25rem; }
  .proberaum-option input { position: absolute; opacity: 0; pointer-events: none; }
  .proberaum-card {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 1.25rem; border-radius: var(--radius-md);
    border: 2px dashed var(--color-primary); background: transparent;
    color: var(--color-text-muted); font-size: 0.95rem; font-weight: 600;
    transition: all 0.2s ease;
  }
  .proberaum-card:hover { background: rgba(172, 72, 57, 0.08); color: var(--color-text); }
  .proberaum-option input:checked + .proberaum-card {
    border-style: solid; background: rgba(172, 72, 57, 0.15);
    color: var(--color-primary-light);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none; border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(172, 72, 57, 0.2);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-muted); opacity: 0.6;
  }

  .form-group select {
    cursor: pointer; appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23999' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat; background-position: right 1rem center; padding-right: 2.5rem;
  }

  .checkbox-label {
    display: flex !important; align-items: flex-start; gap: 0.75rem; cursor: pointer; font-weight: 400 !important;
  }
  .checkbox-label input {
    width: 18px !important; height: 18px; margin-top: 0.15rem; flex-shrink: 0;
    appearance: none; -webkit-appearance: none; border: 2px solid #555;
    border-radius: 4px; background: transparent; cursor: pointer;
    transition: all 0.2s ease; position: relative;
  }
  .checkbox-label input:checked {
    background: var(--color-primary); border-color: var(--color-primary);
  }
  .checkbox-label input:checked::after {
    content: ''; position: absolute; left: 4px; top: 1px;
    width: 6px; height: 10px; border: solid #fff; border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .checkbox-label input:hover { border-color: var(--color-primary-light); }
  .checkbox-label span { font-size: 0.85rem; color: var(--color-text-muted); }
  .checkbox-label span a { color: var(--color-primary-light); }

  .booking-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
  .sidebar-card .card-body h3 { font-size: 1.1rem; margin-bottom: 1rem; }

  .contact-list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .contact-row {
    display: flex; align-items: center; gap: 0.9rem;
    text-decoration: none; color: var(--color-text); font-size: 0.9rem; font-weight: 500;
    transition: color 0.2s ease;
  }
  .contact-row:hover { color: var(--color-primary-light); }
  .contact-icon {
    width: 40px; height: 40px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .contact-icon--phone { background: rgba(172, 72, 57, 0.15); color: var(--color-primary-light); }
  .contact-icon--mail { background: rgba(172, 72, 57, 0.15); color: var(--color-primary-light); }
  .contact-icon--whatsapp { background: rgba(37, 211, 102, 0.15); color: #25d366; }

  .info-list { list-style: none; }
  .info-list li {
    position: relative; padding: 0.4rem 0 0.4rem 1.25rem;
    color: var(--color-text-muted); font-size: 0.9rem;
  }
  .info-list li::before {
    content: ''; position: absolute; left: 0; top: 0.75rem;
    width: 6px; height: 6px; background: var(--color-primary); border-radius: 50%;
  }

  .sidebar-text { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 1rem; }

  /* Datepicker */
  .datepicker-wrap { position: relative; }

  .datepicker-trigger {
    width: 100%; padding: 0.75rem 1rem; background: var(--color-bg-card);
    border: 1px solid var(--color-border); border-radius: var(--radius-md);
    color: var(--color-text-muted); font-family: var(--font-body); font-size: 0.95rem;
    cursor: pointer; display: flex; align-items: center; gap: 0.6rem;
    transition: border-color var(--transition-fast);
  }
  .datepicker-trigger:hover { border-color: var(--color-primary); }
  .datepicker-trigger.has-value { color: var(--color-text); }

  .datepicker-dropdown {
    display: none; position: absolute; top: calc(100% + 0.5rem); left: 0;
    z-index: 100; background: #1a1a1a; border: 1px solid #333;
    border-radius: 16px; padding: 1rem; width: 300px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.5);
  }
  .datepicker-dropdown.open { display: block; }

  .dp-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .dp-month-year {
    font-weight: 700; font-size: 0.95rem; color: #fff;
  }
  .dp-nav {
    background: transparent; border: none; color: #999; cursor: pointer;
    width: 32px; height: 32px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s ease;
  }
  .dp-nav:hover { background: #333; color: var(--color-primary-light); }

  .dp-weekdays {
    display: grid; grid-template-columns: repeat(7, 1fr);
    text-align: center; margin-bottom: 0.4rem;
  }
  .dp-weekdays span {
    font-size: 0.7rem; font-weight: 700; color: #666;
    text-transform: uppercase; letter-spacing: 0.5px; padding: 0.25rem 0;
  }

  .dp-days {
    display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px;
  }

  .success-message {
    padding: 2rem;
    background: rgba(64, 139, 209, 0.1);
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    font-size: 1.1rem;
    text-align: center;
  }

  @media (max-width: 900px) {
    .booking-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<style is:global>
  .dp-day {
    background: transparent; border: 2px solid transparent; color: #ccc; font-size: 0.85rem;
    font-family: 'Rubik', sans-serif; width: 100%; aspect-ratio: 1;
    border-radius: 10px; cursor: pointer; font-weight: 500;
    transition: all 0.15s ease;
  }
  .dp-day:hover { background: #333; color: #fff; }
  .dp-day.today { border-color: #ac4839; color: #c95a4a; }
  .dp-day.selected { background: #ac4839; border-color: #ac4839; color: #fff; font-weight: 700; }
  .dp-day.other-month { color: #333; }
  .dp-day.past { color: #444; cursor: default; }
  .dp-day.past:hover { background: transparent; color: #444; }
</style>

<script>
  // Datepicker
  (() => {
    const trigger = document.getElementById("datepickerTrigger")!;
    const dropdown = document.getElementById("datepickerDropdown")!;
    const label = document.getElementById("datepickerLabel")!;
    const grid = document.getElementById("dpDays")!;
    const monthYear = document.getElementById("dpMonthYear")!;
    const hidden = document.getElementById("date") as HTMLInputElement;
    const prevBtn = document.getElementById("dpPrev")!;
    const nextBtn = document.getElementById("dpNext")!;

    const months = ["Januar","Februar","März","April","Mai","Juni","Juli","August","September","Oktober","November","Dezember"];
    const now = new Date();
    const todayKey = `${now.getFullYear()}-${now.getMonth()}-${now.getDate()}`;
    let currentMonth = now.getMonth();
    let currentYear = now.getFullYear();
    let selectedKey = "";

    function toKey(y: number, m: number, d: number) { return `${y}-${m}-${d}`; }

    function render() {
      monthYear.textContent = `${months[currentMonth]} ${currentYear}`;
      grid.innerHTML = "";
      const first = new Date(currentYear, currentMonth, 1);
      let startDay = first.getDay() - 1; if (startDay < 0) startDay = 6;
      const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
      const prevDays = new Date(currentYear, currentMonth, 0).getDate();

      for (let i = startDay - 1; i >= 0; i--) {
        const btn = document.createElement("button");
        btn.type = "button"; btn.className = "dp-day other-month past";
        btn.textContent = String(prevDays - i);
        grid.appendChild(btn);
      }
      for (let d = 1; d <= daysInMonth; d++) {
        const key = toKey(currentYear, currentMonth, d);
        const date = new Date(currentYear, currentMonth, d, 12, 0, 0);
        const isPast = date < new Date(now.getFullYear(), now.getMonth(), now.getDate(), 12, 0, 0);
        const btn = document.createElement("button");
        btn.type = "button"; btn.className = "dp-day";
        btn.textContent = String(d);
        if (key === todayKey) btn.classList.add("today");
        if (isPast) btn.classList.add("past");
        if (key === selectedKey) btn.classList.add("selected");
        if (!isPast) {
          btn.addEventListener("click", () => {
            selectedKey = key;
            const iso = `${currentYear}-${String(currentMonth+1).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
            hidden.value = iso;
            label.textContent = `${d}. ${months[currentMonth]} ${currentYear}`;
            trigger.classList.add("has-value");
            dropdown.classList.remove("open");
            render();
          });
        }
        grid.appendChild(btn);
      }
      const totalCells = startDay + daysInMonth;
      const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
      for (let i = 1; i <= remaining; i++) {
        const btn = document.createElement("button");
        btn.type = "button"; btn.className = "dp-day other-month past";
        btn.textContent = String(i);
        grid.appendChild(btn);
      }
    }

    trigger.addEventListener("click", () => dropdown.classList.toggle("open"));
    prevBtn.addEventListener("click", () => { currentMonth--; if (currentMonth < 0) { currentMonth = 11; currentYear--; } render(); });
    nextBtn.addEventListener("click", () => { currentMonth++; if (currentMonth > 11) { currentMonth = 0; currentYear++; } render(); });
    document.addEventListener("click", (e) => {
      if (!(e.target as Element).closest(".datepicker-wrap")) dropdown.classList.remove("open");
    });
    render();
  })();

  const form = document.getElementById("bookingForm") as HTMLFormElement;
  const success = document.getElementById("success-message");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = "Wird gesendet..."; }
    try {
      const data = new FormData(form);
      const res = await fetch("/api/send-booking", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: data.get("name"),
          email: data.get("email"),
          phone: data.get("phone"),
          date: data.get("date"),
          eventType: data.get("eventType"),
          location: data.get("location"),
          guests: data.get("guests"),
          message: data.get("message"),
          proberaum: data.get("proberaum"),
        }),
      });
      if (res.ok) {
        form.style.display = "none";
        if (success) {
          success.style.display = "block";
          success.scrollIntoView({ behavior: "smooth", block: "center" });
        }
      } else {
        alert("Fehler beim Senden. Bitte versucht es erneut oder schreibt uns direkt an info@dropzone-band.de");
        if (btn) { btn.disabled = false; btn.textContent = "Anfrage absenden"; }
      }
    } catch (err) {
      alert("Verbindungsfehler. Bitte versucht es erneut oder schreibt uns direkt an info@dropzone-band.de");
      if (btn) { btn.disabled = false; btn.textContent = "Anfrage absenden"; }
    }
  });
</script>
