---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const reviews = [
  { text: 'Dropzone hat unsere Hochzeitsfeier zu etwas Besonderem gemacht. Vielen Dank für Euren reibungslosen und unkomplizierten Ablauf und für die geniale Stimmung an diesem Abend.', author: 'Friederike Kugler', date: '29.04.2025' },
  { text: 'Wir hatten schon 2 tolle Anlässe mit Dropzone: zur Hochzeit auf 2222 m ü.M. in der Schweiz und eine Kongressparty in Amsterdam. Auch diesmal wieder ein Volltreffer. Alles exzellente Musiker mit ausgezeichnetem Feeling für den Moment.', author: 'Nicola Zitzmann', date: '30.06.2024' },
  { text: 'Nur Liebe für diese Band! Auf der Bühne liefern sie alle richtig ab und egal ob 5 oder 50 oder 500 Leute drumherum stehen, sie geben jedem das Gefühl extra für dich zu spielen. 11/10 highly recommend!', author: 'Janina', date: '17.12.2025' },
  { text: 'Tolle Band, phantastisches Entertainment und einfach super sympathische Bandmitglieder. Buchen mit Begeisterungsgarantie. Jederzeit gerne wieder!', author: 'David Pricking', date: '30.07.2024' },
  { text: 'Einzigartige Band mit breitem Repertoire und einer Leadsängerin, deren Stimme unter die Haut geht. Absolut empfehlenswert!', author: 'Anna Gasché', date: '11.06.2024' },
  { text: 'Wir haben unser 25. Jubiläum mit Dropzone gefeiert und sind begeistert! Wir konnten uns blind auf die Band verlassen. Vielen Dank und immer gerne wieder!', author: 'Regina Faller', date: '17.10.2024' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Was kostet eine Hochzeitsband?',
      acceptedAnswer: { '@type': 'Answer', text: 'Die Kosten hängen von Besetzung, Spieldauer und Anfahrt ab. Dropzone bietet flexible Pakete vom Duo bis zur Full-Band. Nutzt unseren Kostenrechner für eine erste Einschätzung oder fragt direkt an.' },
    },
    {
      '@type': 'Question',
      name: 'Wie weit im Voraus sollte man eine Hochzeitsband buchen?',
      acceptedAnswer: { '@type': 'Answer', text: 'Wir empfehlen, mindestens 6–12 Monate im Voraus zu buchen. Beliebte Termine (Mai–September) sind oft früh vergeben.' },
    },
    {
      '@type': 'Question',
      name: 'Spielt Dropzone auch den Eröffnungstanz?',
      acceptedAnswer: { '@type': 'Answer', text: 'Ja! Wir lernen euren Wunschsong und performen ihn live für euren Eröffnungstanz – ein emotionaler Höhepunkt.' },
    },
    {
      '@type': 'Question',
      name: 'Bringt die Band eigene Technik mit?',
      acceptedAnswer: { '@type': 'Answer', text: 'Ja, Dropzone liefert professionelle PA-Anlage und Lichttechnik mit. Ihr müsst euch um nichts kümmern.' },
    },
    {
      '@type': 'Question',
      name: 'Kann man Dropzone auch als kleinere Besetzung buchen?',
      acceptedAnswer: { '@type': 'Answer', text: 'Absolut. Vom akustischen Duo für die Trauung bis zur Full-Band mit 5+ Musikern für die Party – wir passen uns an.' },
    },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Hochzeitsband Stuttgart – Dropzone buchen',
  description: 'Professionelle Hochzeitsband aus Stuttgart für Hochzeiten in Baden-Württemberg und ganz Deutschland. Vom Duo bis zur Full-Band, inklusive Licht- und Soundtechnik. Über 20 Jahre Erfahrung.',
  provider: { '@id': 'https://www.dropzone-band.de/#organization' },
  areaServed: [
    { '@type': 'State', name: 'Baden-Württemberg' },
    { '@type': 'City', name: 'Stuttgart' },
    { '@type': 'Country', name: 'Deutschland' },
    { '@type': 'Country', name: 'Schweiz' },
    { '@type': 'Country', name: 'Österreich' },
  ],
  serviceType: 'Hochzeitsband',
  category: 'Live-Musik für Hochzeiten',
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: '1800',
    highPrice: '5500',
    description: 'Preis abhängig von Besetzungsgröße (Duo bis Full-Band), Spieldauer und Anfahrt. Inklusive professioneller Licht- und Soundtechnik.',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Hochzeitsband-Pakete',
    itemListElement: [
      { '@type': 'Offer', name: 'Duo/Trio – Trauung & Empfang', description: 'Kleine Besetzung für Trauung, Sektempfang und Dinner. Lounge-Musik und Akustik-Arrangements.' },
      { '@type': 'Offer', name: 'Standardbesetzung (5 Musiker)', description: 'Sängerin, Sänger, Keys, Gitarre, Drums – die bewährte Besetzung für Hochzeitsfeiern mit Tanz und Party.' },
      { '@type': 'Offer', name: 'Full-Band mit Extras', description: 'Erweiterte Besetzung mit Bläsern, Percussion oder Background-Vocals für große Feiern.' },
    ],
  },
};
---

<BaseLayout title="Hochzeitsband in Stuttgart und Umgebung" description="Musikalische Höhepunkte für eure Hochzeit. Wir sorgen für die perfekte Party, vom Empfang bis zum großen Finale: DROPZONE – Hochzeitsband aus Stuttgart." schema={[faqSchema, serviceSchema]}>

  <Hero
    title="Die Band für eure Hochzeit 2026"
    subtitle="Die perfekte Hochzeitsband? Eine solche zu finden ist nicht leicht. Das Internet ist prall gefüllt mit Webseiten von Alleinunterhaltern und Hochzeitsbands im Schnauzbart-Look und Glitzersakkos. Wir finden: Es ist höchste Zeit, dem etwas entgegenzusetzen."
    cta={{ label: 'Jetzt anfragen', href: '/booking/' }}
    ctaSecondary={{ label: 'Kostenrechner', href: '/kostenrechner/' }}
    backgroundImage="/images/wp/2016-03-DSC_7487-1.webp"
    backgroundPosition="center 20%"
  />

  <!-- ============ WARUM DROPZONE ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(200, 100, 140, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Eure Hochzeitsband</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Warum ist Dropzone die ideale Band<br/>für eure <span class="text-primary-light">Hochzeit</span>?</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Mit unserer langjährigen Erfahrung wissen wir genau, was eine Hochzeitsfeier zu einem besonderen Ereignis macht. Entscheidend sind Charme, Stil, eine sorgfältig abgestimmte Musikauswahl und eine Live-Band, die für Stimmung sorgt und Gäste jeden Alters begeistert.
          </p>
          <p class="text-white/50 leading-relaxed mb-4">
            Unser Ziel ist es, die Hochzeitsband zu sein, die auch wir selbst für unseren großen Tag wählen würden. Vertraut auf unsere Expertise, um eure Hochzeit in ein unvergessliches Fest zu verwandeln.
          </p>
          <p class="text-white/50 leading-relaxed mb-8">
            Dabei sorgen wir durch mitgelieferte Licht- und Soundtechnik dafür, dass alles reibungsfrei abläuft und ihr euren Tag und eure Hochzeitsband entspannt genießen könnt.
          </p>
          <a href="/booking/" class="btn btn-outline text-sm !py-2.5 !px-5">Jetzt anfragen</a>
        </div>
        <div>
          <div class="relative overflow-hidden rounded-2xl shadow-2xl cursor-zoom-in" id="hochzeitCarousel">
            <div class="flex transition-transform duration-700 ease-out" id="hochzeitTrack">
              {[
                { src: '/images/wp/2024-03-0Q5A3312-Edit-1.webp', alt: 'Hochzeitsband Dropzone' },
                { src: '/images/wp/2016-06-DSC_7487.webp', alt: 'Dropzone auf Hochzeit' },
                { src: '/images/wp/2024-06-Beitragsbild.webp', alt: 'Dropzone Hochzeitsband Live' },
                { src: '/images/wp/2024-02-DSC_8979-scaled.webp', alt: 'Dropzone Hochzeit Atmosphäre' },
              ].map((img) => (
                <div class="w-full flex-shrink-0">
                  <img src={img.src} alt={img.alt} class="w-full aspect-[16/9] object-cover" loading="lazy" />
                </div>
              ))}
            </div>
            <button id="hochzeitPrev" class="absolute top-1/2 left-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Vorheriges Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button id="hochzeitNext" class="absolute top-1/2 right-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Nächstes Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
          <div class="flex gap-2 mt-3" id="hochzeitThumbs">
            {[
              { src: '/images/wp/2024-03-0Q5A3312-Edit-1.webp', alt: 'Hochzeitsband Dropzone' },
              { src: '/images/wp/2016-06-DSC_7487.webp', alt: 'Dropzone auf Hochzeit' },
              { src: '/images/wp/2024-06-Beitragsbild.webp', alt: 'Dropzone Hochzeitsband Live' },
              { src: '/images/wp/2024-02-DSC_8979-scaled.webp', alt: 'Dropzone Hochzeit Atmosphäre' },
            ].map((img, i) => (
              <button class={`flex-1 rounded-lg overflow-hidden border-2 transition-all duration-300 cursor-pointer ${i === 0 ? 'border-primary' : 'border-transparent opacity-50 hover:opacity-80'}`} data-thumb={i}>
                <img src={img.src} alt={img.alt} class="w-full aspect-[16/9] object-cover" loading="lazy" />
              </button>
            ))}
          </div>
          <div id="hochzeitLightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black">
            <button id="hochzeitLbClose" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Schließen">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
            <button id="hochzeitLbPrev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Zurück">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button id="hochzeitLbNext" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Weiter">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <img id="hochzeitLbImage" src="" alt="" class="max-w-[95vw] max-h-[95vh] object-contain" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ INTERVIEW ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 30% 50%, rgba(130, 60, 220, 0.15) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[3fr_2fr] gap-12 md:gap-16 items-center">
        <div>
          <div class="video-wrapper !rounded-2xl shadow-2xl overflow-hidden">
            <iframe src="https://www.youtube-nocookie.com/embed/i4krYK_bW9M" title="Hochzeitsband im Interview – Sarah und Jean-Pierre" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Hochzeitsband im Interview</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">„Drei, vier, Vollgas!"</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Sarah und Jean-Pierre, unsere beiden Frontsänger, nehmen euch in diesem Interview mit auf eine Reise in die Welt der Hochzeitsfeiern.
          </p>
          <p class="text-white/50 leading-relaxed">
            Sie erläutern, was eine wirklich herausragende Coverband von anderen Bands unterscheidet, warum eine Live-Band einem DJ überlegen ist und wie sie einen spontan gewünschten Song während der Fahrt zum Auftritt einstudieren können, ohne dass der Bandbus aus der Spur gerät. Und vieles mehr.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PARTYBAND ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(180, 50, 100, 0.16) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">So könnte eure Party aussehen</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Dropzone is in<br/>the <span class="text-primary-light">House</span></h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Natürlich könnt ihr uns auch elegant haben – mit Schlips, Hut und frisch gebügeltem Outfit. Aber tief in uns schlägt das Herz für Partys, mitreißende Grooves und einen Sound, der bewegt.
          </p>
          <p class="text-white/50 leading-relaxed mb-4">
            Schaut euch unser Partyband-Showreel an: Die Besetzung ist hier etwas größer als unsere Standardformation für private Feiern, aber es gibt euch einen guten Eindruck von der Energie, dem Sound und der Songauswahl, die wir zu Hochzeiten und anderen privaten Events mitbringen.
          </p>
          <p class="text-white/50 leading-relaxed">
            Ab einem gewissen Punkt – vielleicht, wenn Tante Hilde sich schon ins Hotel zurückgezogen hat – sorgen wir dafür, dass die Tanzfläche richtig bebt.
          </p>
        </div>
        <div>
          <div class="video-wrapper !rounded-2xl shadow-2xl overflow-hidden">
            <iframe src="https://www.youtube-nocookie.com/embed/Ju_I95kOqxU" title="Dropzone Partyband Showreel" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ KI SONG ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 40% 35% at 30% 50%, rgba(40, 200, 200, 0.16) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
        <div class="order-2 md:order-1">
          <img src="/images/wp/2025-08-Unbenannt-1-1.webp" alt="Once in a Lifetime Song" class="w-full rounded-3xl shadow-2xl" loading="lazy" />
        </div>
        <div class="order-1 md:order-2">
          <span class="inline-block px-4 py-1.5 bg-primary/15 text-primary-light rounded-full text-sm font-semibold mb-6">Neu: KI-Special</span>
          <h2 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">Once In A<br/>Lifetime Song</h2>
          <p class="text-primary-light font-semibold text-lg mb-4">EUER KI-SONG live gespielt. Einmal im Leben.</p>
          <p class="text-white/55 leading-relaxed mb-6">
            KI macht's möglich: Wir kreieren mit euch euren individuellen KI-Song und spielen ihn live auf eurer Hochzeitsfeier. Einmal im Leben.
          </p>
          <div class="space-y-3 mb-8">
            {['Lyrics erstellen mit unserem Generator', 'Musikstil wählen & an uns senden', 'Wir spielen euren Song live'].map((step, i) => (
              <div class="flex items-center gap-3">
                <span class="flex-shrink-0 w-8 h-8 rounded-full bg-primary text-white text-sm font-bold flex items-center justify-center">{i + 1}</span>
                <span class="text-white/70">{step}</span>
              </div>
            ))}
          </div>
          <a href="/once-in-a-lifetime-song/" class="btn btn-primary">Mehr erfahren</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PROBERAUMKONZERT ============ -->
  <section id="proberaumkonzert" class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 65% 50%, rgba(220, 160, 60, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Für Hochzeitspaare und alle anderen</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Proberaumkonzert</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Ihr habt noch nie oder selten eine Band gebucht und möchtet gerne wissen, mit wem ihr es zu tun habt? Wie wir singen und klingen? Wie wir so drauf sind?
          </p>
          <p class="text-white/50 leading-relaxed mb-6">
            Wir laden euch herzlich ein, uns live zu treffen und ein paar Kostproben unserer Livemusik zu erleben. In regelmäßigen Abständen veranstalten wir sogenannte Proberaumkonzerte, wo wir in entspannter Atmosphäre etwas Musik für euch machen und anschließend alle eure Fragen beantworten. Völlig unverbindlich natürlich. Und was zu Trinken gibt's auch.
          </p>
          <div class="bg-surface-card border border-border rounded-2xl p-6 mb-6">
            <h3 class="text-white font-bold mb-2">Nächstes Proberaumkonzert</h3>
            <p class="text-primary-light font-semibold">17.04.2026, 20 Uhr</p>
            <p class="text-white/50 text-sm">Musikschule Music Planet, Heiligenwiesen 8a, 70327 Stuttgart</p>
          </div>
          <a href="/booking/" class="btn btn-outline text-sm !py-2.5 !px-5">Anmelden</a>
        </div>
        <div>
          <div class="video-wrapper !rounded-2xl shadow-2xl overflow-hidden">
            <iframe src="https://www.youtube-nocookie.com/embed/5Mfx85R0AiE" title="Proberaumkonzert – Sarah und Jean-Pierre erklären" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ ABLAUF ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 50% 50%, rgba(40, 180, 130, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Euer perfekter Tag</p>
        <h2 class="text-4xl md:text-5xl font-bold">So läuft's mit Dropzone</h2>
      </div>

      <div class="max-w-[700px] mx-auto flex flex-col gap-5">
        {[
          { nr: '1', title: 'Trauung & Empfang', text: 'Stimmungsvolle Akustik-Musik während der Zeremonie und zum Sektempfang.' },
          { nr: '2', title: 'Dinner & Hintergrundmusik', text: 'Dezente Live-Musik oder DJ-Playlist zum Essen. Genau richtig für gute Gespräche.' },
          { nr: '3', title: 'Eröffnungstanz', text: 'Euer Wunsch-Song live performt – der emotionale Höhepunkt des Abends.' },
          { nr: '4', title: 'Party!', text: 'Volle Bandbesetzung, volle Tanzfläche, volle Energie – bis in die Nacht.' },
        ].map((step) => (
          <div class="flex gap-5 items-start">
            <span class="flex-shrink-0 w-11 h-11 rounded-full bg-primary text-white text-lg font-bold flex items-center justify-center mt-1">{step.nr}</span>
            <div class="bg-surface-card border border-border rounded-2xl p-5 flex-1">
              <h3 class="text-white font-bold mb-1">{step.title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 25% 50%, rgba(200, 150, 40, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Referenzen? Na klar!</p>
        <h2 class="text-4xl md:text-5xl font-bold">Das sagen andere<br/>Hochzeitspaare über uns.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {reviews.map((r, i) => (
          <blockquote
            class="bg-surface-card border border-border rounded-2xl p-6 hover:border-primary/30 transition-all duration-300 hover:-translate-y-1"
          >
            <div class="text-gold text-sm mb-3">★★★★★</div>
            <p class="text-white/80 leading-relaxed mb-4 text-[0.95rem]">"{r.text}"</p>
            <footer class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-primary/20 flex items-center justify-center text-primary-light font-bold text-sm">
                {r.author[0]}
              </div>
              <div>
                <cite class="text-white font-semibold text-sm not-italic block">{r.author}</cite>
                <time class="text-muted text-xs">{r.date}</time>
              </div>
            </footer>
          </blockquote>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/feedback/" class="btn btn-outline text-sm !py-2.5 !px-6">Alle Bewertungen ansehen</a>
      </div>
    </div>
  </section>

  <!-- ============ FAQ ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 40% 35% at 60% 50%, rgba(130, 60, 220, 0.12) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Gut zu wissen</p>
        <h2 class="text-4xl md:text-5xl font-bold">Häufige Fragen</h2>
      </div>
      <div class="max-w-[750px] mx-auto flex flex-col gap-3">
        {faqSchema.mainEntity.map((item) => (
          <details class="group bg-surface-card border border-border rounded-2xl overflow-hidden cursor-pointer">
            <summary class="flex items-center justify-between gap-4 p-5 font-[Rubik] font-semibold text-white list-none">
              <span>{item.name}</span>
              <svg class="flex-shrink-0 w-5 h-5 text-white/40 group-open:rotate-180 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="px-5 pb-5">
              <p class="text-white/50 text-sm leading-relaxed">{item.acceptedAnswer.text}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Hochzeit Carousel with Thumbs + Lightbox
  (() => {
    const track = document.getElementById('hochzeitTrack');
    const carousel = document.getElementById('hochzeitCarousel');
    const prevBtn = document.getElementById('hochzeitPrev');
    const nextBtn = document.getElementById('hochzeitNext');
    const thumbsContainer = document.getElementById('hochzeitThumbs');
    if (!track || !thumbsContainer) return;

    const total = track.children.length;
    const thumbs = thumbsContainer.querySelectorAll('button');
    let pos = 0;
    let autoTimer: ReturnType<typeof setInterval>;

    const images = Array.from(track.querySelectorAll('img')).map(img => ({
      src: (img as HTMLImageElement).src,
      alt: (img as HTMLImageElement).alt,
    }));

    function go(i: number) {
      pos = ((i % total) + total) % total;
      track.style.transform = `translateX(-${pos * 100}%)`;
      updateThumbs();
    }

    function updateThumbs() {
      thumbs.forEach((t, i) => {
        if (i === pos) {
          t.classList.add('border-primary');
          t.classList.remove('border-transparent', 'opacity-50');
        } else {
          t.classList.remove('border-primary');
          t.classList.add('border-transparent', 'opacity-50');
        }
      });
    }

    thumbs.forEach(t => {
      t.addEventListener('click', () => {
        go(Number(t.getAttribute('data-thumb')));
        resetAuto();
      });
    });

    prevBtn?.addEventListener('click', () => { go(pos - 1); resetAuto(); });
    nextBtn?.addEventListener('click', () => { go(pos + 1); resetAuto(); });

    let sx = 0;
    track.addEventListener('touchstart', (e) => { sx = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      const diff = sx - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) { go(pos + (diff > 0 ? 1 : -1)); resetAuto(); }
    });

    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => go(pos + 1), 5000);
    }

    go(0);
    resetAuto();

    // Lightbox
    const lb = document.getElementById('hochzeitLightbox');
    const lbImg = document.getElementById('hochzeitLbImage') as HTMLImageElement;
    const lbClose = document.getElementById('hochzeitLbClose');
    const lbPrev = document.getElementById('hochzeitLbPrev');
    const lbNext = document.getElementById('hochzeitLbNext');
    if (!lb || !lbImg) return;

    let lbPos = 0;

    function lbShow(i: number) {
      lbPos = ((i % total) + total) % total;
      lbImg.src = images[lbPos].src;
      lbImg.alt = images[lbPos].alt;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function lbHide() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    }

    carousel?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('button')) return;
      lbShow(pos);
    });

    lbClose?.addEventListener('click', lbHide);
    lbPrev?.addEventListener('click', () => lbShow(lbPos - 1));
    lbNext?.addEventListener('click', () => lbShow(lbPos + 1));

    lb.addEventListener('click', (e) => {
      if (e.target === lb) lbHide();
    });

    document.addEventListener('keydown', (e) => {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') lbHide();
      if (e.key === 'ArrowLeft') lbShow(lbPos - 1);
      if (e.key === 'ArrowRight') lbShow(lbPos + 1);
    });
  })();
</script>
