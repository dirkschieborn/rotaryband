---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const members = [
  {
    name: 'Jean-Pierre Domaniwski',
    role: 'Charmanter Frontmann',
    image: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/DZ.016.6990-scaled.jpg',
    bio: 'Jean-Pierres außergewöhnliche Stimme prägt den Sound von Dropzone entscheidend – sein energiegeladenes und maßgeschneidertes Entertainment machen die Shows von Dropzone zu unvergesslichen Live-Acts der Extraklasse.',
    details: 'Jean-Pierre ist Gesangslehrer sowie Gründer und Inhaber der Stuttgarter Musikschule Music Planet. Er ist Songwriter und Produzent im hauseigenen Tonstudio und arbeitet mit namhaften Künstlern zusammen. Jean-Pierre ist Frontmann und Kopf der Band Jake and the Convolution.',
    glow: 'rgba(130, 60, 220, 0.16)',
  },
  {
    name: 'Sarah Abdallah',
    role: 'Bezaubernde Lady am Mikro',
    image: 'https://www.dropzone-band.de/wp-content/uploads/2016/03/DSC_7487-1-1.jpg',
    bio: 'Sarah ist die bezaubernde Sängerin an der Dropzone-Front. Ihre Stimme verleiht dem Dropzone-Sound den besonderen Schliff und macht die Shows von Dropzone zu unverwechselbaren Performances höchster musikalischer Qualität.',
    details: 'Sarah ist gebürtige Hamburgerin und absolvierte ihr Studium in Jazz- und Popgesang an der Stuttgarter Musikhochschule. Sie unterrichtet eine Vielzahl von Gesangsschülern an verschiedenen Musikschulen und schreibt und produziert eigene Musik.',
    glow: 'rgba(200, 100, 140, 0.18)',
  },
  {
    name: 'Dirk Schieborn',
    role: 'Tastenmann',
    image: 'https://www.dropzone-band.de/wp-content/uploads/2024/06/IMG_5896.jpg',
    bio: 'Dirk ist der Mann an den Tasten und den vielen Sounds. Virtuoser Pianist und Soundtüftler in einem, komplettiert er den Dropzone-Sound mit Piano-, Synthesizer- und Orgelklängen.',
    details: 'Dirk studierte klassisches Klavier an der Musikakademie Tübingen. Parallel studierte er Jazz-Piano bei verschiedenen Lehrern. Er ist mit großer Leidenschaft unterwegs als Mathematikprofessor, Unternehmensberater, Pianist sowie Mitgründer und Vorstandsvorsitzender der Spendenkonzertreihe Was uns am Herzen liegt.',
    glow: 'rgba(40, 180, 130, 0.16)',
  },
  {
    name: 'Andy Newman',
    role: 'Der Saitenmagier',
    image: 'https://www.dropzone-band.de/wp-content/uploads/2023/09/10785_Mercedes-Benz-Tech-Motion_Schrittmacher_FotografieEbinger_JPEG_Webresolution_1920Pix__852_4818.jpg',
    bio: 'Andys virtuoses und zugleich gefühlvolles Gitarrenspiel verleiht den Dropzone-Shows einen unvergleichlichen Live-Charakter. Groovende Begleitriffs wechseln sich ab mit brillanten Soli, die Musikliebhaber gerne mal buchstäblich vor ihm niederknien lassen.',
    details: 'Andy studierte Gitarre in Los Angeles und ist ein gefragter Live- und Studiomusiker im süddeutschen Raum.',
    glow: 'rgba(220, 140, 40, 0.16)',
  },
  {
    name: 'Felix Ohngemach',
    role: 'Der Mann für den Beat',
    image: 'https://www.dropzone-band.de/wp-content/uploads/2023/09/10837_Mercedes-Benz-Tech-Motion_Schrittmacher_FotografieEbinger_JPEG_Webresolution_1920Pix__852_4893.jpg',
    bio: 'Felix ist der Drummer von Dropzone und jüngstes Bandmitglied. Seine Beats geben der Band ein stabiles und gleichzeitig virtuoses rhythmisches Fundament.',
    details: 'Felix unterrichtet am DrumLab in Freudenstadt und an anderen Musikschulen zahlreiche Schlagzeugschüler. Er ist ein gefragter Studio- und Livedrummer im süddeutschen Raum; er spielt in verschiedenen Bandprojekten mit, darunter in den Bands Jake and the Convolution und Dizzy Bee.',
    glow: 'rgba(40, 200, 200, 0.16)',
  },
];

const glowPositions = ['70% 50%', '30% 50%', '65% 50%', '35% 50%', '60% 50%'];
---

<BaseLayout title="Wer wir sind" description="Lernt die Musiker von Dropzone kennen – eure Eventband aus Stuttgart.">

  <Hero
    title="Wer wir sind"
    subtitle="Fünf Musiker, eine Mission: Unvergessliche Momente schaffen."
    backgroundImage="https://www.dropzone-band.de/wp-content/uploads/2016/03/DSC_7487-1-1.jpg"
  />

  <!-- Band Members -->
  {members.map((member, i) => (
    <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" style={`background: radial-gradient(ellipse 45% 35% at ${glowPositions[i]}, ${member.glow} 0%, transparent 100%);`}></div>
      <div class="max-w-[1400px] mx-auto px-8">
        <div class={`grid md:grid-cols-2 gap-12 md:gap-16 items-center ${i % 2 === 1 ? 'direction-rtl' : ''}`}>
          <div class={i % 2 === 1 ? 'order-2 md:order-1' : ''}>
            <div class="member-image-container">
              <div class="member-image-glow" style={`background: ${member.glow.replace(/[\d.]+\)$/, '0.4)')};`}></div>
              <img src={member.image} alt={member.name} loading="lazy" class="member-image" />
            </div>
          </div>
          <div class={i % 2 === 1 ? 'order-1 md:order-2' : ''}>
            <span class="inline-block px-4 py-1.5 bg-primary/15 text-primary-light rounded-full text-sm font-semibold mb-4">{member.role}</span>
            <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">{member.name}</h2>
            <p class="text-white/60 leading-relaxed mb-4">{member.bio}</p>
            <p class="text-white/45 leading-relaxed text-sm">{member.details}</p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Band Values -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 50% 50%, rgba(130, 60, 220, 0.12) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Unsere Werte</p>
        <h2 class="text-4xl md:text-5xl font-bold">Was uns ausmacht</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          { nr: '01', title: 'Professionalität', text: 'Eigene PA, Lichttechnik, pünktlich, zuverlässig – wir kümmern uns um alles.' },
          { nr: '02', title: 'Vielseitigkeit', text: 'Akustik-Duo, 5-köpfige Partyband oder mit Extras – wir passen uns eurem Event an.' },
          { nr: '03', title: 'Leidenschaft', text: 'Über zwanzig Jahre Bühnenerfahrung und die Liebe zur Live-Musik in jedem Ton.' },
        ].map((item) => (
          <div class="bg-surface-card border border-border rounded-2xl p-8 text-center hover:border-primary/30 transition-all duration-300">
            <span class="text-4xl font-bold text-primary/30 font-[Rubik] block mb-3">{item.nr}</span>
            <h3 class="text-white font-bold text-lg mb-3">{item.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .member-image-container {
    position: relative;
  }

  .member-image-glow {
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    filter: blur(40px);
    z-index: 0;
  }

  .member-image {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 1.5rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }
</style>
