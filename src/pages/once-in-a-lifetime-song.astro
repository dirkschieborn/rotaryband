---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Once In A Lifetime Song – Euer KI-Song"
  description="Euer persönlicher KI-Song, live gespielt auf eurer Hochzeitsfeier. Einzigartig, emotional, unvergesslich."
>

  <Hero
    title="Once In A Lifetime Song"
    subtitle="EUER KI-SONG live gespielt. Einmal im Leben."
    backgroundImage="/images/wp/2025-08-Unbenannt-1-1.webp"
    backgroundPosition="center 25%"
  />

  <!-- ============ INTRO ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 50% 50%, rgba(200, 100, 140, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[800px] mx-auto px-8 text-center">
      <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Euer Song. Euer Moment.</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-8 leading-tight">Ein Song nur für <span class="text-primary-light">euch</span></h2>
      <p class="text-white/65 text-lg leading-relaxed mb-5">
        Stellt euch vor: Ein Song, der nur für euch geschrieben wurde – mit eurer Geschichte, euren Erinnerungen, euren Worten. Und dann spielt ihn eine Live-Band auf eurer Hochzeitsfeier.
      </p>
      <p class="text-white/50 text-lg leading-relaxed mb-5">
        Mit modernster KI-Technologie kreieren wir gemeinsam mit euch einen einzigartigen Song. Ihr liefert die Story, wir machen daraus Musik.
      </p>
      <p class="text-white/50 text-lg leading-relaxed mb-10">
        Und das Beste: Wir spielen euren Song live auf eurer Feier. Ein absolut einmaliges Erlebnis.
      </p>
      <a href="#generator" class="btn btn-primary">Jetzt Lyrics erstellen</a>
    </div>
  </section>

  <!-- ============ SO FUNKTIONIERT'S ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 50% 50%, rgba(40, 180, 130, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">In 5 Schritten</p>
        <h2 class="text-4xl md:text-5xl font-bold">So funktioniert's</h2>
      </div>
      <div class="max-w-[700px] mx-auto flex flex-col gap-5">
        {[
          { nr: '1', title: 'Lyrics erstellen', text: 'Nutzt unseren Lyrics-Generator weiter unten. Gebt eure Namen, eure Geschichte und besondere Momente ein – unsere KI schreibt daraus euren Songtext.' },
          { nr: '2', title: 'Musikstil wählen', text: 'Wählt euren bevorzugten Musikstil – ob Pop-Ballade, Neo-Soul, Rock oder Hochzeitswalzer.' },
          { nr: '3', title: 'KI erstellt den Song', text: 'Wir erstellen auf Basis eurer Lyrics und Stilwünsche einen vollständigen, professionellen Song.' },
          { nr: '4', title: 'Vorab-Preview', text: 'Ihr bekommt eine Vorab-Version zum Anhören. Wir passen an, bis es perfekt ist.' },
          { nr: '5', title: 'Live auf eurer Feier', text: 'Der große Moment: Dropzone spielt euren persönlichen Song live auf eurer Hochzeitsfeier.' },
        ].map((step) => (
          <div class="flex gap-5 items-start">
            <span class="flex-shrink-0 w-11 h-11 rounded-full bg-primary text-white text-lg font-bold flex items-center justify-center mt-1">{step.nr}</span>
            <div class="bg-surface-card border border-border rounded-2xl p-5 flex-1">
              <h3 class="text-white font-bold mb-1">{step.title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{step.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ LYRICS GENERATOR ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden" id="generator">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 30% 50%, rgba(130, 60, 220, 0.15) 0%, transparent 100%);"></div>
    <div class="max-w-[900px] mx-auto px-8 relative z-10">
      <div class="text-center mb-12">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Step 1</p>
        <h2 class="text-4xl md:text-5xl font-bold">Lyrics Generator</h2>
        <p class="text-white/50 mt-4 max-w-[600px] mx-auto">Gebt eure Details ein und unsere KI schreibt euren persönlichen Songtext. Ihr könnt das Ergebnis danach noch bearbeiten.</p>
      </div>

      <!-- Generator Form -->
      <form id="lyricsForm" class="bg-surface-card border border-border rounded-2xl p-8 md:p-10">
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div>
            <label for="bride" class="block text-white font-semibold text-sm mb-2">Name 1 (z.B. Braut) *</label>
            <input type="text" id="bride" name="bride" required placeholder="z.B. Michelle"
              class="w-full bg-surface border border-border rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-primary focus:outline-none transition-colors" />
          </div>
          <div>
            <label for="groom" class="block text-white font-semibold text-sm mb-2">Name 2 (z.B. Bräutigam) *</label>
            <input type="text" id="groom" name="groom" required placeholder="z.B. Daniel"
              class="w-full bg-surface border border-border rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-primary focus:outline-none transition-colors" />
          </div>
        </div>

        <div class="mb-6">
          <label for="story" class="block text-white font-semibold text-sm mb-2">Eure Geschichte</label>
          <textarea id="story" name="story" rows="4" placeholder="Erzählt uns etwas über euch: Wie habt ihr euch kennengelernt? Was verbindet euch? Besondere Momente, Hobbys, Reisen..."
            class="w-full bg-surface border border-border rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-primary focus:outline-none transition-colors resize-y"></textarea>
        </div>

        <div class="grid md:grid-cols-2 gap-6 mb-8">
          <!-- Sprache -->
          <div>
            <p class="text-white font-semibold text-sm mb-3">Sprache</p>
            <div class="flex gap-3">
              <label class="flex-1 cursor-pointer">
                <input type="radio" name="language" value="Deutsch" checked class="peer hidden" />
                <span class="block text-center py-2.5 px-4 rounded-xl border border-border text-white/60 text-sm font-semibold peer-checked:border-primary peer-checked:text-primary-light peer-checked:bg-primary/10 transition-all">Deutsch</span>
              </label>
              <label class="flex-1 cursor-pointer">
                <input type="radio" name="language" value="Englisch" class="peer hidden" />
                <span class="block text-center py-2.5 px-4 rounded-xl border border-border text-white/60 text-sm font-semibold peer-checked:border-primary peer-checked:text-primary-light peer-checked:bg-primary/10 transition-all">Englisch</span>
              </label>
            </div>
          </div>

          <!-- Stimmung -->
          <div>
            <p class="text-white font-semibold text-sm mb-3">Stimmung</p>
            <div class="flex gap-3 flex-wrap">
              <label class="cursor-pointer">
                <input type="radio" name="mood" value="ruhig und gechillt" class="peer hidden" />
                <span class="block py-2.5 px-4 rounded-xl border border-border text-white/60 text-sm font-semibold peer-checked:border-primary peer-checked:text-primary-light peer-checked:bg-primary/10 transition-all">Ruhig</span>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="mood" value="positiv und energetisch" checked class="peer hidden" />
                <span class="block py-2.5 px-4 rounded-xl border border-border text-white/60 text-sm font-semibold peer-checked:border-primary peer-checked:text-primary-light peer-checked:bg-primary/10 transition-all">Energetisch</span>
              </label>
              <label class="cursor-pointer">
                <input type="radio" name="mood" value="lässig und cool" class="peer hidden" />
                <span class="block py-2.5 px-4 rounded-xl border border-border text-white/60 text-sm font-semibold peer-checked:border-primary peer-checked:text-primary-light peer-checked:bg-primary/10 transition-all">Lässig</span>
              </label>
            </div>
          </div>
        </div>

        <button type="submit" id="generateBtn" class="btn btn-primary w-full text-center text-base !py-3.5">
          Lyrics generieren
        </button>

        <!-- Loading -->
        <div id="loadingState" class="hidden mt-6 text-center">
          <div class="inline-flex items-center gap-3 text-primary-light">
            <svg class="animate-spin w-5 h-5" viewBox="0 0 24 24" fill="none">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span class="font-semibold">Eure Lyrics werden geschrieben...</span>
          </div>
        </div>

        <!-- Error -->
        <div id="errorState" class="hidden mt-6">
          <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 text-red-400 text-sm"></div>
        </div>
      </form>

      <!-- Result -->
      <div id="resultSection" class="hidden mt-8">
        <div class="bg-surface-card border border-border rounded-2xl p-8 md:p-10">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-white font-bold text-xl font-[Rubik]">Eure Lyrics</h3>
            <button id="copyBtn" class="text-sm text-primary-light hover:text-white transition-colors font-semibold cursor-pointer">Kopieren</button>
          </div>
          <textarea id="lyricsOutput" rows="16"
            class="w-full bg-surface border border-border rounded-xl px-5 py-4 text-white/80 leading-relaxed focus:border-primary focus:outline-none transition-colors resize-y text-[0.95rem]"></textarea>

          <p class="text-white/40 text-sm mt-4">Ihr könnt den Text oben direkt bearbeiten. Wenn ihr zufrieden seid, wählt unten euren Musikstil und sendet uns alles zu.</p>

          <!-- Musikstil + Absenden -->
          <div class="mt-8 pt-8 border-t border-border">
            <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Step 2: Musikstil wählen & absenden</p>
            <div class="flex gap-3 flex-wrap mb-6">
              {['Rock', 'Pop', 'Neo-Soul', 'Hochzeitswalzer'].map((style, i) => (
                <label class="cursor-pointer">
                  <input type="radio" name="style" value={style} checked={i === 1} class="peer hidden" />
                  <span class="block py-2.5 px-5 rounded-xl border border-border text-white/60 text-sm font-semibold peer-checked:border-primary peer-checked:text-primary-light peer-checked:bg-primary/10 transition-all">{style}</span>
                </label>
              ))}
            </div>

            <div class="mb-6">
              <label for="contactEmail" class="block text-white font-semibold text-sm mb-2">Eure E-Mail-Adresse *</label>
              <input type="email" id="contactEmail" required placeholder="email@beispiel.de"
                class="w-full bg-surface border border-border rounded-xl px-4 py-3 text-white placeholder-white/30 focus:border-primary focus:outline-none transition-colors" />
            </div>

            <button id="sendBtn" class="btn btn-primary w-full text-center text-base !py-3.5 cursor-pointer">
              Lyrics & Stilwunsch an Dropzone senden
            </button>

            <div id="sendLoading" class="hidden mt-4 text-center">
              <div class="inline-flex items-center gap-3 text-primary-light">
                <svg class="animate-spin w-5 h-5" viewBox="0 0 24 24" fill="none">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                <span class="font-semibold">Wird gesendet...</span>
              </div>
            </div>

            <div id="sendSuccess" class="hidden mt-4">
              <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 text-green-400 text-sm text-center font-semibold">
                Gesendet! Wir melden uns bei euch. Danke!
              </div>
            </div>

            <div id="sendError" class="hidden mt-4">
              <div class="bg-red-500/10 border border-red-500/30 rounded-xl p-4 text-red-400 text-sm text-center"></div>
            </div>
          </div>
        </div>

        <!-- Nochmal generieren -->
        <div class="text-center mt-6">
          <button id="regenerateBtn" class="btn btn-outline text-sm !py-2.5 !px-5 cursor-pointer">Neue Lyrics generieren</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BEISPIELE ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(220, 140, 40, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Hörbeispiele</p>
        <h2 class="text-4xl md:text-5xl font-bold">So kann's klingen</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-[1100px] mx-auto">

        <!-- Beispiel 1 -->
        <div class="bg-surface-card border border-border rounded-2xl overflow-hidden hover:border-primary/30 transition-all duration-300">
          <img src="/images/wp/2025-08-Design-ohne-Titel-2.webp" alt="Michelle und Daniel" class="w-full aspect-square object-cover" style="object-position: center 20%" loading="lazy" />
          <div class="p-8">
            <p class="text-primary-light/70 text-xs font-semibold uppercase tracking-widest mb-2">Beispiel 1</p>
            <h3 class="text-white font-bold text-xl font-[Rubik] mb-4">Michelle & Daniel</h3>

            <div class="flex flex-wrap gap-2 mb-5">
              <span class="px-3 py-1 bg-primary/10 text-primary-light rounded-full text-xs font-semibold">Neo-Soul</span>
              <span class="px-3 py-1 bg-white/5 text-white/50 rounded-full text-xs font-semibold">Englisch</span>
              <span class="px-3 py-1 bg-white/5 text-white/50 rounded-full text-xs font-semibold">Positiv & energetisch</span>
            </div>

            <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-2">Eingabe in den Generator:</p>
            <p class="text-white/55 text-sm leading-relaxed mb-5 italic">
              „Daniel ist ein geselliger, humorvoller Mensch mit gutem Gespür für Wortwitze. Michelle ist die Kreative und Künstlerische von den beiden und singt gerne und gut. Beide reisen gerne in warme Gefilde wie etwa Südafrika, Spanien, Sizilien. Sie lieben Kultur, gutes Essen und guten Wein, pflegen einen urbanen Lifestyle. Sie sind gerne auf ihren Vespas on the road und mögen die Band ‚Rage against the machine'."
            </p>

            <p class="text-white font-semibold text-sm mb-3">Song: „Ride With Me"</p>
            <audio controls class="w-full mb-4">
              <source src="/images/wp/2025-08-Ride-With-Me-final.mp3" type="audio/mpeg" />
            </audio>

            <details class="group cursor-pointer">
              <summary class="flex items-center gap-2 text-primary-light text-sm font-semibold list-none">
                <span>Songtext anzeigen</span>
                <svg class="w-4 h-4 group-open:rotate-180 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="mt-4 p-4 bg-surface rounded-xl">
                <pre class="text-white/60 text-sm leading-relaxed whitespace-pre-wrap font-sans">Verse 1:
You paint the world with every song you sing,
He cracks a joke that makes the silence ring.
You chase the sun from Cape Town to Madrid,
Two hearts in motion – that's how you live.

Sipping reds in old cafés,
Vespas flying down bougainvillea ways.
You talk art, he throws in puns,
But love like yours needs no reruns.

Chorus:
So ride with me through every street,
Through summer nights and urban beats.
From rooftops high to ocean breeze,
We'll dance in wine and olive trees.
Michelle and Daniel, wild and free –
The perfect blend of fire and ease.

Verse 2:
You find the rhythm in city skies,
He finds the punchline, no surprise.
Culture's your compass, passion your map,
You dive in deep, no time for gaps.

With soul and spice and Vespa speed,
You're chasing stories, not just need.
You rage with love, no compromise –
Your rebel hearts just harmonize.

Chorus:
So ride with me through every street,
Through summer nights and urban beats.
From rooftops high to ocean breeze,
We'll dance in wine and olive trees.
Michelle and Daniel, wild and free –
The perfect blend of fire and ease.

Bridge:
When the noise gets loud and the lights go cold,
You hold each other, fierce and bold.
No map too far, no dream too wide –
You've got the world, and love as guide.

Chorus (Final):
So ride with me through every street,
Through summer nights and urban beats.
From rooftops high to ocean breeze,
We'll dance in wine and olive trees.
Michelle and Daniel, wild and free –
This love's a masterpiece in key.</pre>
              </div>
            </details>
          </div>
        </div>

        <!-- Beispiel 2 -->
        <div class="bg-surface-card border border-border rounded-2xl overflow-hidden hover:border-primary/30 transition-all duration-300">
          <img src="/images/wp/2025-08-Unbenannt-1-1.webp" alt="Emily und Jakob" class="w-full aspect-square object-cover" style="object-position: center 30%" loading="lazy" />
          <div class="p-8">
            <p class="text-primary-light/70 text-xs font-semibold uppercase tracking-widest mb-2">Beispiel 2</p>
            <h3 class="text-white font-bold text-xl font-[Rubik] mb-4">Emily & Jakob</h3>

            <div class="flex flex-wrap gap-2 mb-5">
              <span class="px-3 py-1 bg-primary/10 text-primary-light rounded-full text-xs font-semibold">Hochzeitswalzer</span>
              <span class="px-3 py-1 bg-white/5 text-white/50 rounded-full text-xs font-semibold">Deutsch</span>
              <span class="px-3 py-1 bg-white/5 text-white/50 rounded-full text-xs font-semibold">Ruhig & gechillt</span>
            </div>

            <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-2">Eingabe in den Generator:</p>
            <p class="text-white/55 text-sm leading-relaxed mb-5 italic">
              „Emily und Jakob kennen sich seit dem Kindergarten, haben sich jahrelang aus den Augen verloren und vor einem Jahr aus beruflichen Gründen in Rio de Janeiro wiedergetroffen. Es war Liebe auf den zweiten Blick. Seitdem sind sie unzertrennlich und haben schon nach drei Wochen entschieden, zu heiraten. Seitdem leben sie ein Leben zwischen Deutschland und Südamerika."
            </p>

            <p class="text-white font-semibold text-sm mb-3">Song: „Ein Blick, ein Jahr, für immer"</p>
            <audio controls class="w-full mb-4">
              <source src="/images/wp/2025-08-Ein-Blick-ein-Jahr-fuer-immer-final.mp3" type="audio/mpeg" />
            </audio>

            <details class="group cursor-pointer">
              <summary class="flex items-center gap-2 text-primary-light text-sm font-semibold list-none">
                <span>Songtext anzeigen</span>
                <svg class="w-4 h-4 group-open:rotate-180 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="mt-4 p-4 bg-surface rounded-xl">
                <pre class="text-white/60 text-sm leading-relaxed whitespace-pre-wrap font-sans">Vers 1:
Im Sandkasten fing es einmal leise an,
Zwei Kinder, die das Leben noch nicht fassen kann.
Dann kamen die Jahre, verloren die Spur,
Und jeder ging weiter auf seiner Tour.

Doch manchmal schreibt das Leben ganz still
Geschichten, die das Herz wiederfüllen will.
In Rio, bei Regen, auf Pflaster aus Stein,
Fiel der Blick – und ihr wart nicht allein.

Chorus:
Ein Blick, ein Jahr, für immer –
Ein Kuss im warmen Licht.
Ihr tanzt durch Zeit und Himmel,
und tragt das Glück im Gesicht.
Vom Kindergarten bis heute,
von Fernweh zu Zuhaus –
Ihr lebt ein großes Wunder
im kleinsten Lebenslauf.

Vers 2:
Drei Wochen – und ihr wusstet genau:
Das ist kein Spiel, das ist echte Bau.
Ihr plantet nicht – ihr habt's gespürt,
Ein Band, das mit Stille berührt.

Zwischen Samba, Sehnsucht und deutschen Wäldern,
Findet ihr Heimat in zwei Welten.
Ihr reist nicht davon – ihr reist hinein,
In ein Leben aus Herz und Sein.

Chorus:
Ein Blick, ein Jahr, für immer –
Ein Kuss im warmen Licht.
Ihr tanzt durch Zeit und Himmel,
und tragt das Glück im Gesicht.
Vom Kindergarten bis heute,
von Fernweh zu Zuhaus –
Ihr lebt ein großes Wunder
im kleinsten Lebenslauf.

Bridge:
Was lange verschwunden, kommt stärker zurück,
Zwei Herzen im Takt – ein stilles Glück.
Und was wie Zufall begann,
ist jetzt euer Lebensplan.

Chorus (Finale):
Ein Blick, ein Jahr, für immer –
Ein Ja, das ewig klingt.
Ein Tanz durch Tag und Träume,
der euch für immer umringt.
Von Rio bis zu den Sternen,
von damals bis heut –
Emily und Jakob –
ihr seid für alle Zeit.</pre>
              </div>
            </details>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="py-24 md:py-32 bg-surface">
    <div class="max-w-[700px] mx-auto px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Fragen?</h2>
      <p class="text-white/50 leading-relaxed mb-8">Kontaktiert uns und wir besprechen gemeinsam, wie euer Once In A Lifetime Song aussehen kann.</p>
      <a href="/booking/" class="btn btn-primary">Jetzt anfragen</a>
    </div>
  </section>

</BaseLayout>

<script>
  (() => {
    const form = document.getElementById('lyricsForm') as HTMLFormElement;
    const generateBtn = document.getElementById('generateBtn') as HTMLButtonElement;
    const loadingState = document.getElementById('loadingState')!;
    const errorState = document.getElementById('errorState')!;
    const resultSection = document.getElementById('resultSection')!;
    const lyricsOutput = document.getElementById('lyricsOutput') as HTMLTextAreaElement;
    const copyBtn = document.getElementById('copyBtn')!;
    const regenerateBtn = document.getElementById('regenerateBtn')!;
    const sendBtn = document.getElementById('sendBtn') as HTMLButtonElement;
    const sendLoading = document.getElementById('sendLoading')!;
    const sendSuccess = document.getElementById('sendSuccess')!;
    const sendError = document.getElementById('sendError')!;

    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const bride = (document.getElementById('bride') as HTMLInputElement).value.trim();
      const groom = (document.getElementById('groom') as HTMLInputElement).value.trim();
      const story = (document.getElementById('story') as HTMLTextAreaElement).value.trim();
      const language = (form.querySelector('input[name="language"]:checked') as HTMLInputElement).value;
      const mood = (form.querySelector('input[name="mood"]:checked') as HTMLInputElement).value;

      // Show loading
      generateBtn.disabled = true;
      generateBtn.classList.add('opacity-50');
      loadingState.classList.remove('hidden');
      errorState.classList.add('hidden');
      resultSection.classList.add('hidden');

      try {
        const response = await fetch('/api/generate-lyrics', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ bride, groom, story, language, mood }),
        });

        const data = await response.json();

        if (!response.ok || data.error) {
          throw new Error(data.error || 'Fehler bei der Generierung');
        }

        lyricsOutput.value = data.lyrics;
        resultSection.classList.remove('hidden');
        resultSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch (err: any) {
        errorState.classList.remove('hidden');
        errorState.querySelector('div')!.textContent = `Fehler: ${err.message}. Bitte versucht es erneut.`;
      } finally {
        generateBtn.disabled = false;
        generateBtn.classList.remove('opacity-50');
        loadingState.classList.add('hidden');
      }
    });

    // Copy lyrics
    copyBtn.addEventListener('click', () => {
      lyricsOutput.select();
      navigator.clipboard.writeText(lyricsOutput.value);
      copyBtn.textContent = 'Kopiert!';
      setTimeout(() => { copyBtn.textContent = 'Kopieren'; }, 2000);
    });

    // Regenerate
    regenerateBtn.addEventListener('click', () => {
      resultSection.classList.add('hidden');
      form.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Send lyrics via Resend
    sendBtn.addEventListener('click', async () => {
      const contactEmail = (document.getElementById('contactEmail') as HTMLInputElement).value.trim();
      if (!contactEmail) {
        (document.getElementById('contactEmail') as HTMLInputElement).focus();
        return;
      }

      const lyrics = lyricsOutput.value;
      const styleEl = document.querySelector('input[name="style"]:checked') as HTMLInputElement;
      const style = styleEl ? styleEl.value : 'Pop';
      const bride = (document.getElementById('bride') as HTMLInputElement).value.trim();
      const groom = (document.getElementById('groom') as HTMLInputElement).value.trim();

      sendBtn.disabled = true;
      sendBtn.classList.add('opacity-50');
      sendLoading.classList.remove('hidden');
      sendSuccess.classList.add('hidden');
      sendError.classList.add('hidden');

      try {
        const response = await fetch('/api/send-song', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ bride, groom, lyrics, style, email: contactEmail }),
        });

        const data = await response.json();

        if (!response.ok || data.error) {
          throw new Error(data.error || 'Fehler beim Senden');
        }

        sendSuccess.classList.remove('hidden');
        sendBtn.classList.add('hidden');
      } catch (err: any) {
        sendError.classList.remove('hidden');
        sendError.querySelector('div')!.textContent = `Fehler: ${err.message}. Bitte versucht es erneut.`;
      } finally {
        sendBtn.disabled = false;
        sendBtn.classList.remove('opacity-50');
        sendLoading.classList.add('hidden');
      }
    });
  })();
</script>
