---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const specials = [
  {
    title: 'Akustik-Set',
    description: 'Intime Atmosphäre mit akustischen Arrangements eurer Lieblingssongs. Perfekt für Trauungen, Empfänge und Dinner.',
    image: '/images/special-akustik.jpg',
    features: ['Duo bis Quartett', 'Eigene Beschallung', 'Stimmungsvolle Beleuchtung'],
  },
  {
    title: 'Partyband',
    description: 'Volle Bandbesetzung, volle Power. Wir füllen die Tanzfläche und sorgen für Party bis in die Nacht.',
    image: '/images/special-party.jpg',
    features: ['5-köpfige Besetzung', 'Professionelle PA & Licht', 'DJ-Service inklusive'],
  },
  {
    title: 'Once in a Lifetime Song',
    description: 'Euer persönlicher Song, mit KI komponiert und von uns live auf der Bühne performt. Ein absolutes Highlight.',
    image: '/images/special-ki-song.jpg',
    features: ['KI-generierter Song', 'Live performt', 'Einzigartiges Erlebnis'],
    link: '/once-in-a-lifetime-song/',
  },
  {
    title: 'Unplugged Konzert',
    description: 'Clubatmosphäre pur. Unsere Songs in besonderen Unplugged-Arrangements – nah, persönlich, einzigartig.',
    image: '/images/special-unplugged.jpg',
    features: ['Besondere Arrangements', 'Intime Atmosphäre', 'Wunschsongs möglich'],
  },
  {
    title: 'Festival-Show',
    description: 'Grosse Bühne, grosser Sound, grosse Show. Dropzone in voller Festival-Besetzung mit allem was dazu gehört.',
    image: '/images/special-festival.jpg',
    features: ['Erweiterte Besetzung möglich', 'Volle Bühnenshow', 'Eigene Produktion'],
  },
  {
    title: 'DJ & Band Kombi',
    description: 'Das Beste aus beiden Welten: Live-Band und DJ nahtlos kombiniert für den perfekten Abend.',
    image: '/images/special-dj.jpg',
    features: ['Nahtlose Übergänge', 'Durchgehende Musik', 'Ein Ansprechpartner'],
  },
];
---

<BaseLayout title="Showkonzepte & Specials" description="Entdeckt unsere Showkonzepte – von Akustik bis Festival, vom KI-Song bis zur DJ-Band-Kombi.">

  <Hero
    title="Showkonzepte & Specials"
    subtitle="Mehr als nur Musik – entdeckt, was alles möglich ist."
    backgroundImage="/images/hero-specials.jpg"
  />

  <section class="section">
    <div class="container">
      <div class="specials-list">
        {specials.map((special, i) => (
          <div class={`special-row ${i % 2 === 1 ? 'reversed' : ''}`}>
            <div class="special-image-wrap">
              <img src={special.image} alt={special.title} loading="lazy" />
            </div>
            <div class="special-content">
              <h2>{special.title}</h2>
              <p class="special-desc">{special.description}</p>
              <ul class="special-features">
                {special.features.map((feature) => (
                  <li>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-light)" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
                    {feature}
                  </li>
                ))}
              </ul>
              {special.link ? (
                <a href={special.link} class="btn btn-primary">Mehr erfahren</a>
              ) : (
                <a href="/booking/" class="btn btn-outline">Anfragen</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .specials-list {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .special-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .special-row.reversed {
    direction: rtl;
  }

  .special-row.reversed > * {
    direction: ltr;
  }

  .special-image-wrap img {
    width: 100%;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .special-content h2 {
    margin-bottom: 1rem;
  }

  .special-desc {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .special-features {
    list-style: none;
    margin-bottom: 2rem;
  }

  .special-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .special-row,
    .special-row.reversed {
      grid-template-columns: 1fr;
      direction: ltr;
    }
  }
</style>
