---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const testimonials = [
  {
    text: 'Dropzone hat unsere Hochzeit unvergesslich gemacht. Die Tanzfläche war die ganze Nacht voll! Die Band hat perfekt auf unsere Wünsche reagiert und die Stimmung war einfach grandios.',
    author: 'Sarah & Michael',
    event: 'Hochzeit',
    rating: 5,
  },
  {
    text: 'Professionell, sympathisch und musikalisch auf höchstem Niveau. Unsere Firmenfeier war ein voller Erfolg. Alle Gäste waren begeistert.',
    author: 'Thomas K.',
    event: 'Firmenevent, Mercedes-Benz',
    rating: 5,
  },
  {
    text: 'Die Stimmung war grandios! Dropzone versteht es, das Publikum mitzureissen. Von der ersten Minute an war die Energie im Raum spürbar.',
    author: 'Lisa & Jan',
    event: 'Hochzeit',
    rating: 5,
  },
  {
    text: 'Wir haben Dropzone für unser Stadtfest gebucht und waren restlos begeistert. Professioneller Auftritt, super Sound und eine Band, die ihr Publikum liebt.',
    author: 'Gemeinde Ditzingen',
    event: 'Stadtfest',
    rating: 5,
  },
  {
    text: 'Zum zweiten Mal bei uns – und beim nächsten Event wieder! Dropzone ist einfach zuverlässig, sympathisch und musikalisch top.',
    author: 'Sandra M.',
    event: 'Geburtstag',
    rating: 5,
  },
  {
    text: 'Die Band hat unsere Erwartungen übertroffen. Tolle Songauswahl, unglaubliche Energie und super nette Leute.',
    author: 'Andreas & Julia',
    event: 'Hochzeit',
    rating: 5,
  },
];

const stars = (count: number) => '★'.repeat(count) + '☆'.repeat(5 - count);
---

<BaseLayout
  title="Feedback"
  description="Was unsere Kunden über Dropzone sagen – Bewertungen und Erfahrungen."
  schema={testimonials.map((t) => ({
    '@context': 'https://schema.org',
    '@type': 'Review',
    itemReviewed: { '@id': 'https://www.dropzone-band.de/#organization' },
    reviewRating: { '@type': 'Rating', ratingValue: t.rating, bestRating: 5 },
    author: { '@type': 'Person', name: t.author },
    reviewBody: t.text,
  }))}
>

  <Hero
    title="Feedback"
    subtitle="Was unsere Kunden sagen."
    backgroundImage="/images/hero-feedback.jpg"
  />

  <section class="section">
    <div class="container">
      <div class="feedback-stats">
        <div class="stat">
          <span class="stat-number">5.0</span>
          <span class="stat-stars">★★★★★</span>
          <span class="stat-label">Durchschnittliche Bewertung</span>
        </div>
        <div class="stat">
          <span class="stat-number">200+</span>
          <span class="stat-label">Erfolgreiche Events</span>
        </div>
        <div class="stat">
          <span class="stat-number">100%</span>
          <span class="stat-label">Weiterempfehlung</span>
        </div>
      </div>

      <div class="testimonials-grid">
        {testimonials.map((t) => (
          <blockquote class="testimonial-card card">
            <div class="card-body">
              <div class="testimonial-stars">{stars(t.rating)}</div>
              <p class="testimonial-text">"{t.text}"</p>
              <footer class="testimonial-footer">
                <cite class="testimonial-author">{t.author}</cite>
                <span class="testimonial-event">{t.event}</span>
              </footer>
            </div>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .feedback-stats {
    display: flex;
    justify-content: center;
    gap: 4rem;
    margin-bottom: 4rem;
    padding: 2.5rem;
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
  }

  .stat {
    text-align: center;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary-light);
  }

  .stat-stars {
    display: block;
    color: #f5a623;
    font-size: 1.2rem;
    margin: 0.25rem 0;
  }

  .stat-label {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .testimonial-card {
    border: none;
  }

  .testimonial-stars {
    color: #f5a623;
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }

  .testimonial-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    font-style: italic;
    margin-bottom: 1.25rem;
  }

  .testimonial-footer {
    display: flex;
    flex-direction: column;
  }

  .testimonial-author {
    color: #fff;
    font-weight: 600;
    font-style: normal;
    font-size: 0.95rem;
  }

  .testimonial-event {
    color: var(--color-primary-light);
    font-size: 0.85rem;
    margin-top: 0.15rem;
  }

  @media (max-width: 768px) {
    .feedback-stats {
      flex-direction: column;
      gap: 2rem;
      align-items: center;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
