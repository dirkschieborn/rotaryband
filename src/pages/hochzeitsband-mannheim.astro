---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Hochzeitsband Mannheim"
  description="Hochzeitsband in Mannheim gesucht? Dropzone liefert Live-Musik für eure Hochzeitsfeier im Rhein-Neckar-Raum. Professionell, maßgeschneidert, unvergesslich."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Hochzeitsband Mannheim – Dropzone',
    description: 'Live-Musik für Hochzeitsfeiern in Mannheim und dem Rhein-Neckar-Raum.',
    provider: { '@id': 'https://www.dropzone-band.de/#organization' },
    areaServed: { '@type': 'City', name: 'Mannheim' },
    serviceType: 'Hochzeitsband',
  }}
>

  <Hero
    title="Hochzeitsband in Mannheim"
    subtitle="Rundum-Sorglos-Hochzeit in Mannheim und dem Rhein-Neckar-Raum."
    backgroundImage="/images/wp/2016-03-DSC_7487-1-1.webp"
    cta={{ label: 'Jetzt anfragen', href: '/booking/' }}
    ctaSecondary={{ label: 'Kostenrechner', href: '/kostenrechner/' }}
  />

  <section class="section">
    <div class="container">
      <div class="content-grid">
        <div>
          <h2 class="section-title" style="text-align:left;">Eure Hochzeitsband für Mannheim</h2>
          <p>
            Ihr sucht eine Hochzeitsband in Mannheim? Dropzone ist eure Live-Band aus Stuttgart,
            die regelmäßig in Mannheim und dem gesamten Rhein-Neckar-Raum für unvergessliche
            Hochzeitsfeiern sorgt.
          </p>
          <p>
            Vom stilvollen Sektempfang über das Dinner bis zum ausgelassenen Partyabend –
            wir begleiten euren großen Tag mit einem perfekt abgestimmten Soundtrack.
            Rock, Pop, Soul, aktuelle Charts und zeitlose Klassiker: Unser vielseitiges
            Repertoire lässt keine Wünsche offen.
          </p>
          <p>
            Mit Sängerin Sarah und Sänger Jean-Pierre an der Front, charmanter Moderation
            und über 20 Jahren Bühnenerfahrung sind wir mehr als nur eine Hochzeitsband –
            wir sind euer Partner für einen perfekten Abend.
          </p>
        </div>
        <div>
          <img
            src="/images/wp/2016-03-DSC_7487-1-1.webp"
            alt="Dropzone als Hochzeitsband"
            class="rounded-image"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <h2 class="section-title">Was uns auszeichnet</h2>
      <div class="divider"></div>
      <div class="features-grid">
        <div class="feature-card">
          <h3>Maßgeschneidert</h3>
          <p>Jede Hochzeit ist einzigartig. Wir stimmen Musikauswahl, Lautstärke und Timing individuell auf euren Ablauf ab.</p>
        </div>
        <div class="feature-card">
          <h3>Rundum-Sorglos</h3>
          <p>Professionelle Licht- und Tontechnik, DJ-Service vor und nach der Band – alles aus einer Hand.</p>
        </div>
        <div class="feature-card">
          <h3>Kein Schlager</h3>
          <p>Bei uns gibt's keine Schunkelmusik. Unser Sound ist modern, groovy und bringt jede Tanzfläche zum Beben.</p>
        </div>
        <div class="feature-card">
          <h3>Erfahrung</h3>
          <p>Über 20 Jahre Bühnenerfahrung, hunderte Hochzeiten, immer professionell und mit Herz.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="text-align:center; max-width:700px;">
      <h2 class="section-title">Eure Hochzeit in Mannheim</h2>
      <p>
        Ob im Barockschloss Mannheim, in einer Eventlocation am Neckar oder im
        gemütlichen Landgasthof – wir kommen zu euch und machen eure Hochzeitsfeier
        zu einem unvergesslichen Erlebnis.
      </p>
      <div style="margin-top:2rem; display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="/booking/" class="btn btn-primary btn-large">Jetzt anfragen</a>
        <a href="/die-band-fur-eure-hochzeit/" class="btn btn-outline btn-large">Mehr über Hochzeiten</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .content-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .rounded-image {
    width: 100%;
    border-radius: var(--radius-xl);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  .section-dark { background: var(--color-surface-elevated); }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .feature-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.5rem;
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    font-size: 0.88rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  p { color: var(--color-muted); line-height: 1.7; margin-bottom: 1rem; }

  @media (max-width: 900px) {
    .content-grid { grid-template-columns: 1fr; }
    .features-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 500px) {
    .features-grid { grid-template-columns: 1fr; }
  }
</style>
