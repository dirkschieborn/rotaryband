  }
  .result-table td.col-qty,
  .result-table td.col-price {
    text-align: right;
    font-family: var(--font-heading);
    font-weight: 600;
  }
  .result-table tfoot td {
    font-weight: 700;
    font-family: var(--font-heading);
    border-bottom: none;
  }
  .result-table .row-subtotal td {
    border-top: 1px solid var(--color-border);
