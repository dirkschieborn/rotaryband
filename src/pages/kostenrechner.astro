  /* Responsive */
  @media (max-width: 700px) {
    .calc-wrapper { padding: 1.5rem; }
    .style-grid { grid-template-columns: 1fr; padding-left: 0; }
    .step-hint { padding-left: 0; }
    .datepicker-wrap { margin-left: 0; }
    .addon-grid { padding-left: 0; }
    .addon-content { flex-wrap: wrap; }
    .addon-price { width: 100%; margin-left: calc(44px + 1rem); margin-top: 0.25rem; }
    .inquiry-row { grid-template-columns: 1fr; }
    .cta-section { padding: 1.5rem; }
  }
</style>

<style is:global>
  .dp-day {
    background: transparent; border: 2px solid transparent; color: #ccc; font-size: 0.85rem;
    font-family: 'Rubik', sans-serif; width: 100%; aspect-ratio: 1;
    border-radius: 10px; cursor: pointer; font-weight: 500;
    transition: all 0.15s ease;
  }
  .dp-day:hover { background: #333; color: #fff; }
  .dp-day.today { border-color: #7c3aed; color: #a855f7; }
  .dp-day.selected { background: #7c3aed; border-color: #7c3aed; color: #fff; font-weight: 700; }
  .dp-day.other-month { color: #333; }
  .dp-day.past { color: #444; cursor: default; }
  .dp-day.past:hover { background: transparent; color: #444; }
</style>

<script>
  // ===== State =====
  const state = {
    styles: {
      party: { active: false, sets: 1, price: 950, label: 'Party' },
      standardtanz: { active: false, sets: 1, price: 700, label: 'Standardtanz' },
      dinner: { active: false, sets: 1, price: 500, label: 'Dinner / Lounge' },
    } as Record<string, { active: boolean; sets: number; price: number; label: string }>,
    addons: {
      trauung: { active: false, price: 400, label: 'Begleitung Trauungsfeier' },
      dj: { active: false, price: 750, label: 'DJ-Service' },
    } as Record<string, { active: boolean; price: number; label: string }>,
  };

  const BASIS_PRICE = 3000;

  // ===== Datepicker =====
  (() => {
    const trigger = document.getElementById("datepickerTrigger")!;
    const dropdown = document.getElementById("datepickerDropdown")!;
    const label = document.getElementById("datepickerLabel")!;
    const grid = document.getElementById("dpDays")!;
    const monthYear = document.getElementById("dpMonthYear")!;
    const prevBtn = document.getElementById("dpPrev")!;
    const nextBtn = document.getElementById("dpNext")!;

    const months = ["Januar","Februar","März","April","Mai","Juni","Juli","August","September","Oktober","November","Dezember"];
    const now = new Date();
    const todayKey = `${now.getFullYear()}-${now.getMonth()}-${now.getDate()}`;
    let currentMonth = now.getMonth();
    let currentYear = now.getFullYear();
    let selectedKey = "";

    function toKey(y: number, m: number, d: number) { return `${y}-${m}-${d}`; }

    function render() {
      monthYear.textContent = `${months[currentMonth]} ${currentYear}`;
      grid.innerHTML = "";
      const first = new Date(currentYear, currentMonth, 1);
      let startDay = first.getDay() - 1; if (startDay < 0) startDay = 6;
      const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
      const prevDays = new Date(currentYear, currentMonth, 0).getDate();

      for (let i = startDay - 1; i >= 0; i--) {
        const btn = document.createElement("button");
        btn.type = "button"; btn.className = "dp-day other-month past";
        btn.textContent = String(prevDays - i);
        grid.appendChild(btn);
      }
      for (let d = 1; d <= daysInMonth; d++) {
        const key = toKey(currentYear, currentMonth, d);
        const date = new Date(currentYear, currentMonth, d, 12, 0, 0);
        const isPast = date < new Date(now.getFullYear(), now.getMonth(), now.getDate(), 12, 0, 0);
        const btn = document.createElement("button");
        btn.type = "button"; btn.className = "dp-day";
        btn.textContent = String(d);
        if (key === todayKey) btn.classList.add("today");
        if (isPast) btn.classList.add("past");
        if (key === selectedKey) btn.classList.add("selected");
        if (!isPast) {
          btn.addEventListener("click", () => {
            selectedKey = key;
            label.textContent = `${d}. ${months[currentMonth]} ${currentYear}`;
            trigger.classList.add("has-value");
            dropdown.classList.remove("open");
            render();
          });
        }
        grid.appendChild(btn);
      }
      const totalCells = startDay + daysInMonth;
      const remaining = totalCells % 7 === 0 ? 0 : 7 - (totalCells % 7);
      for (let i = 1; i <= remaining; i++) {
        const btn = document.createElement("button");
        btn.type = "button"; btn.className = "dp-day other-month past";
        btn.textContent = String(i);
        grid.appendChild(btn);
      }
    }

    trigger.addEventListener("click", () => dropdown.classList.toggle("open"));
    prevBtn.addEventListener("click", () => { currentMonth--; if (currentMonth < 0) { currentMonth = 11; currentYear--; } render(); });
    nextBtn.addEventListener("click", () => { currentMonth++; if (currentMonth > 11) { currentMonth = 0; currentYear++; } render(); });
    document.addEventListener("click", (e) => {
      if (!(e.target as Element).closest(".datepicker-wrap")) dropdown.classList.remove("open");
    });
    render();
  })();

  // ===== Style Toggle Buttons =====
  document.querySelectorAll<HTMLButtonElement>('[data-style-btn]').forEach(btn => {
    btn.addEventListener('click', () => {
      const style = btn.dataset.styleBtn!;
      state.styles[style].active = !state.styles[style].active;
      btn.closest('.style-card')!.classList.toggle('active', state.styles[style].active);
      updateCalculation();
    });
  });

  // ===== Set Counters =====
  document.querySelectorAll<HTMLButtonElement>('.counter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target!;
      const action = btn.dataset.action!;
      const s = state.styles[target];
      if (action === 'increase' && s.sets < 6) s.sets++;
      if (action === 'decrease' && s.sets > 1) s.sets--;
      document.querySelector<HTMLSpanElement>(`[data-count="${target}"]`)!.textContent = String(s.sets);
      document.querySelector<HTMLSpanElement>(`[data-duration="${target}"]`)!.textContent = `${s.sets * 45} Min.`;
      updateCalculation();
    });
  });

  // ===== Add-on Checkboxes =====
  document.getElementById('addonTrauung')!.addEventListener('change', (e) => {
    state.addons.trauung.active = (e.target as HTMLInputElement).checked;
    updateCalculation();
  });
  document.getElementById('addonDJ')!.addEventListener('change', (e) => {
    state.addons.dj.active = (e.target as HTMLInputElement).checked;
    updateCalculation();
  });

  // ===== Calculation =====
  function formatEur(n: number) {
    return n.toLocaleString('de-DE') + ' €';
  }

  function updateCalculation() {
    const resultEl = document.getElementById('calcResult')!;
    const tbody = document.getElementById('resultBody')!;
    const tfoot = document.getElementById('resultFoot')!;

    const activeStyles = Object.entries(state.styles).filter(([, v]) => v.active);

    if (activeStyles.length === 0) {
      resultEl.style.display = 'none';
      return;
    }

    resultEl.style.display = 'block';

    // Build table body
    let html = '';
    let setsTotal = 0;

    for (const [, s] of activeStyles) {
      const lineTotal = s.sets * s.price;
      setsTotal += lineTotal;
      html += `<tr>
        <td>${s.label} <span style="color:var(--color-muted);font-size:0.8rem;">(${s.sets} × ${formatEur(s.price)})</span></td>
        <td class="col-qty">${s.sets}</td>
        <td class="col-price">${formatEur(lineTotal)}</td>
      </tr>`;
    }

    tbody.innerHTML = html;

    // Build footer
    let footHtml = '';

    // Subtotal sets
    footHtml += `<tr class="row-subtotal">
      <td colspan="2">Gesamtsumme Sets</td>
      <td class="col-price">${formatEur(setsTotal)}</td>
    </tr>`;

    // Basis price logic
    const bandPrice = Math.max(setsTotal, BASIS_PRICE);
    if (setsTotal < BASIS_PRICE) {
      footHtml += `<tr class="row-basis">
        <td colspan="3" style="text-align:left;">
          Der Mindestpreis für einen Auftritt unserer Band beträgt ${formatEur(BASIS_PRICE)}.
        </td>
      </tr>`;
    }

    footHtml += `<tr class="row-subtotal">
      <td colspan="2">Gesamtpreis Band</td>
      <td class="col-price">${formatEur(bandPrice)}</td>
    </tr>`;

    // Add-ons
    let addonsTotal = 0;
    for (const [, a] of Object.entries(state.addons)) {
      if (a.active) {
        addonsTotal += a.price;
        footHtml += `<tr class="row-addon">
          <td colspan="2">${a.label}</td>
          <td class="col-price">+ ${formatEur(a.price)}</td>
        </tr>`;
      }
    }

    // Final price
    const endPrice = bandPrice + addonsTotal;
    footHtml += `<tr class="row-total">
      <td colspan="2">Endpreis</td>
      <td class="col-price">${formatEur(endPrice)}</td>
    </tr>`;

    tfoot.innerHTML = footHtml;

    // Update hidden field for form submission
    updateHiddenCalc();
  }

  // ===== Build calculation text for email =====
  function buildCalcText(): string {
    const activeStyles = Object.entries(state.styles).filter(([, v]) => v.active);
    if (activeStyles.length === 0) return '(keine Auswahl)';

    let lines: string[] = [];
    let setsTotal = 0;

    for (const [, s] of activeStyles) {
      const lineTotal = s.sets * s.price;
      setsTotal += lineTotal;
      lines.push(`${s.label}: ${s.sets} Set(s) × ${s.price} € = ${lineTotal.toLocaleString('de-DE')} €`);
    }

    lines.push(`---`);
    lines.push(`Gesamtsumme Sets: ${setsTotal.toLocaleString('de-DE')} €`);

    const bandPrice = Math.max(setsTotal, BASIS_PRICE);
    if (setsTotal < BASIS_PRICE) {
      lines.push(`(Mindestpreis greift: ${BASIS_PRICE.toLocaleString('de-DE')} €)`);
    }
    lines.push(`Gesamtpreis Band: ${bandPrice.toLocaleString('de-DE')} €`);

    let addonsTotal = 0;
    for (const [, a] of Object.entries(state.addons)) {
      if (a.active) {
        addonsTotal += a.price;
        lines.push(`+ ${a.label}: ${a.price.toLocaleString('de-DE')} €`);
      }
    }

    const endPrice = bandPrice + addonsTotal;
    lines.push(`---`);
    lines.push(`ENDPREIS: ${endPrice.toLocaleString('de-DE')} €`);

    return lines.join('\n');
  }

  function updateHiddenCalc() {
    const el = document.getElementById('hiddenCalc') as HTMLInputElement | null;
    if (el) el.value = buildCalcText();

    const dateEl = document.getElementById('hiddenDate') as HTMLInputElement | null;
    const dateLabel = document.getElementById('datepickerLabel');
    if (dateEl && dateLabel && dateLabel.textContent !== 'Datum wählen') {
      dateEl.value = dateLabel.textContent || '';
    }
  }

  // ===== Inquiry Form Submission =====
  const inquiryForm = document.getElementById('inquiryForm') as HTMLFormElement;
  const inquirySuccess = document.getElementById('inquirySuccess');

  inquiryForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    updateHiddenCalc();

    const btn = document.getElementById('inquirySubmit') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Wird gesendet...'; }

    try {
      const data = new FormData(inquiryForm);
      const res = await fetch('/api/send-kostenrechner', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: data.get('name'),
          email: data.get('email'),
          phone: data.get('phone'),
          message: data.get('message'),
          wunschtermin: data.get('wunschtermin'),
          kalkulation: data.get('kalkulation'),
        }),
      });

      if (res.ok) {
        inquiryForm.style.display = 'none';
        if (inquirySuccess) {
          inquirySuccess.style.display = 'block';
          inquirySuccess.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      } else {
        alert('Fehler beim Senden. Bitte versucht es erneut oder schreibt uns direkt an info@dropzone-band.de');
        if (btn) { btn.disabled = false; btn.textContent = 'Jetzt unverbindlich Verfügbarkeit prüfen'; }
      }
    } catch {
      alert('Verbindungsfehler. Bitte versucht es erneut oder schreibt uns direkt an info@dropzone-band.de');
      if (btn) { btn.disabled = false; btn.textContent = 'Jetzt unverbindlich Verfügbarkeit prüfen'; }
    }
  });
</script>
