  }
  .result-table .row-basis td {
    color: var(--color-muted);
    font-size: 0.85rem;
    font-weight: 500;
    padding-top: 0.4rem;
    padding-bottom: 0.4rem;
  }
  .result-table .row-addon td {
    color: #ccc;
  }
  .result-table .row-total td {
    border-top: 2px solid var(--color-primary);
    padding-top: 1rem;
    font-size: 1.2rem;
    color: #fff;
  }
  .result-table .row-total .col-price {
    color: var(--color-primary-light);
    font-size: 1.3rem;
  }

  .result-hint {
    color: var(--color-muted);
    font-size: 0.8rem;
    margin-top: 1.25rem;
    text-align: center;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  /* CTA Section */
  .cta-section {
    position: relative;
    margin-top: 2.5rem;
    padding: 2.5rem;
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.12) 0%, rgba(168, 85, 247, 0.06) 100%);
    border: 2px solid rgba(124, 58, 237, 0.35);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }
  .cta-glow {
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(ellipse, rgba(124, 58, 237, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
    color: #fff;
    position: relative;
  }
  .cta-title svg {
    color: var(--color-primary-light);
    flex-shrink: 0;
  }
  .cta-subtitle {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin-bottom: 1.75rem;
    position: relative;
  }

  /* Inquiry Form */
  .inquiry-form {
    position: relative;
  }
  .inquiry-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .inquiry-field {
    margin-bottom: 1rem;
  }
  .inquiry-field label {
    display: block;
    font-size: 0.88rem;
    font-weight: 600;
    color: #ddd;
    margin-bottom: 0.4rem;
  }
  .inquiry-field .optional {
    font-weight: 400;
    color: var(--color-muted);
    font-size: 0.8rem;
  }
  .inquiry-field input:not([type="checkbox"]),
  .inquiry-field textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    color: #e0e0e0;
    font-family: var(--font-body);
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }
  .inquiry-field input:focus,
  .inquiry-field textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.2);
