    margin-bottom: 1rem;
  }
  .inquiry-success h4 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
    color: #fff;
  }
  .inquiry-success p {
    color: var(--color-muted);
    font-size: 0.95rem;
    max-width: 420px;
