---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
---

<BaseLayout title="Private Events" description="Dropzone für eure private Feier – Hochzeit, Geburtstag, Jubiläum und mehr.">

  <Hero
    title="Private Events"
    subtitle="Hochzeit, Geburtstag, Jubiläum – wir machen eure Feier unvergesslich."
    cta={{ label: 'Jetzt anfragen', href: '/booking/' }}
    backgroundImage="/images/downloads/DSC_7487-1-2.jpg"
  />

  <!-- ============ EIN HOCH AUF EUCH ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(200, 100, 140, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Eure Feier</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Ein Hoch auf <span class="text-primary-light">euch!</span></h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Lasst uns gemeinsam die perfekten musikalischen Vibes für euren besonderen Tag kreieren – mit Stil, Eleganz und jeder Menge guter Musik. Mit mehr als zwanzig Jahren Erfahrung machen wir eure Hochzeits- oder Geburtstagsfeier unvergesslich.
          </p>
          <p class="text-white/50 leading-relaxed mb-8">
            Dabei sorgen wir durch mitgelieferte Licht- und Soundtechnik dafür, dass alles reibungsfrei abläuft und ihr euren Tag entspannt genießen könnt.
          </p>
          <a href="/booking/" class="btn btn-outline text-sm !py-2.5 !px-5">Unverbindlich anfragen</a>
        </div>
        <div>
          <div class="relative overflow-hidden rounded-2xl shadow-2xl cursor-zoom-in" id="privateCarousel">
            <div class="flex transition-transform duration-700 ease-out" id="privateTrack">
              {[
                { src: '/images/downloads/0960_D-LIGHT_021211.jpg', alt: 'Private Feier mit Dropzone' },
                { src: '/images/downloads/DSC02444.jpg', alt: 'Private Party' },
                { src: '/images/downloads/DSC02439-2.jpg', alt: 'Feier mit Dropzone' },
              ].map((img) => (
                <div class="w-full flex-shrink-0">
                  <img src={img.src} alt={img.alt} class="w-full aspect-[16/9] object-cover" loading="lazy" />
                </div>
              ))}
            </div>
            <button id="privatePrev" class="absolute top-1/2 left-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Vorheriges Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button id="privateNext" class="absolute top-1/2 right-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Nächstes Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
          <div class="flex gap-2 mt-3" id="privateThumbs">
            {[
              { src: '/images/downloads/0960_D-LIGHT_021211.jpg', alt: 'Private Feier mit Dropzone' },
              { src: '/images/downloads/DSC02444.jpg', alt: 'Private Party' },
              { src: '/images/downloads/DSC02439-2.jpg', alt: 'Feier mit Dropzone' },
            ].map((img, i) => (
              <button class={`flex-1 rounded-lg overflow-hidden border-2 transition-all duration-300 cursor-pointer ${i === 0 ? 'border-primary' : 'border-transparent opacity-50 hover:opacity-80'}`} data-thumb={i}>
                <img src={img.src} alt={img.alt} class="w-full aspect-[16/9] object-cover" loading="lazy" />
              </button>
            ))}
          </div>
          <div id="privateLightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black">
            <button id="privateLbClose" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Schließen">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
            <button id="privateLbPrev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Zurück">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button id="privateLbNext" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Weiter">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <img id="privateLbImage" src="" alt="" class="max-w-[95vw] max-h-[95vh] object-contain" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ LIVE ERLEBEN ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 30% 50%, rgba(130, 60, 220, 0.15) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[3fr_2fr] gap-12 md:gap-16 items-center">
        <div>
          <div class="video-wrapper !rounded-2xl shadow-2xl overflow-hidden">
            <iframe src="https://www.youtube.com/embed/5Mfx85R0AiE" title="Proberaumkonzert" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Live erleben</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Proberaumkonzert</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Ihr möchtet wissen, mit wem ihr es zu tun habt? Wie wir singen und klingen? Wir laden euch herzlich ein, uns live zu treffen und ein paar Kostproben unserer Livemusik zu erleben.
          </p>
          <p class="text-white/50 leading-relaxed">
            In regelmäßigen Abständen veranstalten wir Proberaumkonzerte in entspannter Atmosphäre. Völlig unverbindlich natürlich. Und was zu Trinken gibt's auch.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PARTYBAND ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(180, 50, 100, 0.16) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">So könnte eure Party aussehen</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Dropzone is in<br/>the <span class="text-primary-light">House</span></h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Ob elegant oder ausgelassen – wir passen uns eurem Anlass an. Unser Partyband-Showreel gibt euch einen guten Eindruck von der Energie, dem Sound und der Songauswahl.
          </p>
          <p class="text-white/50 leading-relaxed">
            Ab einem gewissen Punkt sorgen wir dafür, dass die Tanzfläche richtig bebt.
          </p>
        </div>
        <div>
          <div class="video-wrapper !rounded-2xl shadow-2xl overflow-hidden">
            <iframe src="https://www.youtube.com/embed/Ju_I95kOqxU" title="Dropzone Partyband Showreel" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="py-24 md:py-32 bg-surface">
    <div class="text-center">
      <a href="/booking/" class="btn btn-primary">Jetzt anfragen</a>
    </div>
  </section>

</BaseLayout>

<script>
  // Private Carousel with Thumbs + Lightbox
  (() => {
    const track = document.getElementById('privateTrack');
    const carousel = document.getElementById('privateCarousel');
    const prevBtn = document.getElementById('privatePrev');
    const nextBtn = document.getElementById('privateNext');
    const thumbsContainer = document.getElementById('privateThumbs');
    if (!track || !thumbsContainer) return;

    const total = track.children.length;
    const thumbs = thumbsContainer.querySelectorAll('button');
    let pos = 0;
    let autoTimer: ReturnType<typeof setInterval>;

    const images = Array.from(track.querySelectorAll('img')).map(img => ({
      src: (img as HTMLImageElement).src,
      alt: (img as HTMLImageElement).alt,
    }));

    function go(i: number) {
      pos = ((i % total) + total) % total;
      track.style.transform = `translateX(-${pos * 100}%)`;
      updateThumbs();
    }

    function updateThumbs() {
      thumbs.forEach((t, i) => {
        if (i === pos) {
          t.classList.add('border-primary');
          t.classList.remove('border-transparent', 'opacity-50');
        } else {
          t.classList.remove('border-primary');
          t.classList.add('border-transparent', 'opacity-50');
        }
      });
    }

    thumbs.forEach(t => {
      t.addEventListener('click', () => {
        go(Number(t.getAttribute('data-thumb')));
        resetAuto();
      });
    });

    prevBtn?.addEventListener('click', () => { go(pos - 1); resetAuto(); });
    nextBtn?.addEventListener('click', () => { go(pos + 1); resetAuto(); });

    let sx = 0;
    track.addEventListener('touchstart', (e) => { sx = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      const diff = sx - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) { go(pos + (diff > 0 ? 1 : -1)); resetAuto(); }
    });

    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => go(pos + 1), 5000);
    }

    go(0);
    resetAuto();

    // Lightbox
    const lb = document.getElementById('privateLightbox');
    const lbImg = document.getElementById('privateLbImage') as HTMLImageElement;
    const lbClose = document.getElementById('privateLbClose');
    const lbPrev = document.getElementById('privateLbPrev');
    const lbNext = document.getElementById('privateLbNext');
    if (!lb || !lbImg) return;

    let lbPos = 0;

    function lbShow(i: number) {
      lbPos = ((i % total) + total) % total;
      lbImg.src = images[lbPos].src;
      lbImg.alt = images[lbPos].alt;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function lbHide() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    }

    carousel?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('button')) return;
      lbShow(pos);
    });

    lbClose?.addEventListener('click', lbHide);
    lbPrev?.addEventListener('click', () => lbShow(lbPos - 1));
    lbNext?.addEventListener('click', () => lbShow(lbPos + 1));

    lb.addEventListener('click', (e) => {
      if (e.target === lb) lbHide();
    });

    document.addEventListener('keydown', (e) => {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') lbHide();
      if (e.key === 'ArrowLeft') lbShow(lbPos - 1);
      if (e.key === 'ArrowRight') lbShow(lbPos + 1);
    });
  })();
</script>
