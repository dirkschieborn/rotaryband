---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
---

<BaseLayout title="Festivals und Stadtfeste – Dropzone" description="Dropzone ist der Garant für energiegeladene Auftritte auf Stadtfesten, Open Airs und Festivals. Let's rock!">

  <Hero
    title="Festivals und Stadtfeste"
    subtitle="Let's rock! Dropzone ist der Garant für energiegeladene Auftritte auf Stadtfesten, Open Airs und Festivals!"
    cta={{ label: 'Booking anfragen', href: '/booking/' }}
    backgroundImage="https://www.dropzone-band.de/wp-content/uploads/2014/07/DSC_5450.jpg"
    backgroundPosition="center 20%"
  />

  <!-- ============ JUMP JUMP ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(200, 100, 140, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Jump, jump!</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Let's <span class="text-primary-light">rock!</span></h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Wir woll'n euch springen sehen! Feiert mit uns das Fest der Livemusik – die Energie, die Begeisterung, die Spielfreude, die uns packt, wenn wir auf die Bühne dürfen. Und ihr seid Teil der Party!
          </p>
          <p class="text-white/50 leading-relaxed mb-8">
            Mit einem mitreißenden Repertoire und dynamischer Bühnenpräsenz bringen wir jede Veranstaltung zum Beben. Bucht uns als perfekten musikalischen Act für euer nächstes Stadtfest, Open Air oder Festival – Let's rock the crowd together!
          </p>
          <a href="/booking/" class="btn btn-outline text-sm !py-2.5 !px-5">Jetzt anfragen</a>
        </div>
        <div>
          {/* Main image */}
          <div class="relative overflow-hidden rounded-2xl shadow-2xl cursor-zoom-in" id="festivalCarousel">
            <div class="flex transition-transform duration-700 ease-out" id="festivalTrack">
              {[
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/08/DZ-043.7934.jpg', alt: 'Dropzone auf Festival' },
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/08/DZ-136.8300.jpg', alt: 'Dropzone Live' },
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/DZ.001.6293-scaled.jpg', alt: 'Dropzone Stadtfest' },
              ].map((img) => (
                <div class="w-full flex-shrink-0">
                  <img src={img.src} alt={img.alt} class="w-full aspect-[16/9] object-cover" loading="lazy" />
                </div>
              ))}
            </div>
            <button id="festivalPrev" class="absolute top-1/2 left-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Vorheriges Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button id="festivalNext" class="absolute top-1/2 right-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Nächstes Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
          {/* Thumbs */}
          <div class="flex gap-2 mt-3" id="festivalThumbs">
            {[
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/08/DZ-043.7934.jpg', alt: 'Dropzone auf Festival' },
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/08/DZ-136.8300.jpg', alt: 'Dropzone Live' },
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/DZ.001.6293-scaled.jpg', alt: 'Dropzone Stadtfest' },
            ].map((img, i) => (
              <button class={`flex-1 rounded-lg overflow-hidden border-2 transition-all duration-300 cursor-pointer ${i === 0 ? 'border-primary' : 'border-transparent opacity-50 hover:opacity-80'}`} data-thumb={i}>
                <img src={img.src} alt={img.alt} class="w-full aspect-[16/9] object-cover" loading="lazy" />
              </button>
            ))}
          </div>
        </div>

        {/* Carousel Lightbox */}
        <div id="festivalLightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black">
          <button id="festivalLbClose" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Schließen">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
          <button id="festivalLbPrev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Zurück">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button id="festivalLbNext" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Weiter">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
          <img id="festivalLbImage" src="" alt="" class="max-w-[95vw] max-h-[95vh] object-contain" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SHOWREEL ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 30% 50%, rgba(40, 180, 130, 0.16) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[3fr_2fr] gap-12 md:gap-16 items-center">
        <div>
          <div class="video-wrapper !rounded-2xl shadow-2xl overflow-hidden">
            <iframe src="https://www.youtube.com/embed/FHQzYjMm2VQ" title="Dropzone Showreel Festivals" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Rocken. Sowas von.</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Auf die Zwölf</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Unser Showreel „Festivals": Ein MashUp aus zwei fetten Gigs – dem Hafenscherbenfest Ditzingen, wo wir als Headliner am Start waren, und dem Live-Konzert für Mercedes-Benz auf der Open-Air-Bühne des Mercedes-Benz-Museums in Stuttgart.
          </p>
          <p class="text-white/50 leading-relaxed">
            Dropzone ist euer Live-Act für Open Air, Festivals, Stadtfeste. Let's rock.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BESETZUNGEN ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 50% 50%, rgba(130, 60, 220, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Own the Stage!</p>
        <h2 class="text-4xl md:text-5xl font-bold">Besetzungen</h2>
        <p class="text-white/50 mt-4 max-w-[700px] mx-auto">Zwei Besetzungsvarianten: eine mittlere für die typische Stadtfest-Bühne, eine große für große Festival-Bühnen.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-5 relative z-10">
        {[
          { title: 'City Event', label: 'Standardbesetzung', desc: 'Sechsköpfige Besetzung für Stadtfeste normaler Größe. Bei Bedarf mit eigenem Tontechniker und Technik über unseren Partner DOSONI VT.', image: 'https://www.dropzone-band.de/wp-content/uploads/2014/07/DSC_5450.webp' },
          { title: 'Fat Festival', label: 'Große Besetzung', desc: 'Das große Line-Up für Festival-Bühnen mit Bläser-Section, Percussion, Background-Vocals und mehr. Für das ganz große Konzerterlebnis.', image: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/DZ.001.6293-980x653.webp' },
        ].map((pkg) => (
          <div class="bg-surface-card border border-border rounded-2xl overflow-hidden hover:border-primary/30 transition-all duration-300">
            <img src={pkg.image} alt={pkg.title} class="w-full aspect-[16/9] object-cover" loading="lazy" />
            <div class="p-8">
              <p class="text-primary-light/70 text-xs font-semibold uppercase tracking-widest mb-2">{pkg.label}</p>
              <h3 class="text-white font-bold text-2xl font-[Rubik] mb-3">{pkg.title}</h3>
              <p class="text-white/50 leading-relaxed text-sm">{pkg.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TECHNIK-PAKETE ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 65% 50%, rgba(40, 200, 200, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Licht. Ton. Leidenschaft.</p>
        <h2 class="text-4xl md:text-5xl font-bold">Technik-Pakete</h2>
        <p class="text-white/50 mt-4 max-w-[700px] mx-auto">Dank jahrelanger Erfahrung und professioneller Partner bieten wir hochwertige Eventtechnik und Bühnen für jeden Anlass.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-5 mb-16">
        {[
          { title: 'Technik City Event', label: 'Standardpaket', desc: 'Perfekt auf die sechsköpfige Besetzung zugeschnitten: angemessene Beleuchtung und Beschallung inklusive eigenem Ton- und Lichttechniker.' },
          { title: 'Technik Fat Festival', label: 'Großes Paket', desc: 'Maßgeschneiderte Veranstaltungstechnik und Techniker-Team für die große Besetzung. State-of-the-Art-Equipment. Auf Wunsch mit Bühnen- und Traversenaufbauten.' },
        ].map((item) => (
          <div class="bg-surface-card border border-border rounded-2xl p-6 hover:border-primary/30 transition-all duration-300">
            <p class="text-primary-light/70 text-xs font-semibold uppercase tracking-widest mb-2">{item.label}</p>
            <h3 class="text-white font-bold text-lg font-[Rubik] mb-3">{item.title}</h3>
            <p class="text-white/50 leading-relaxed text-sm">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- Dosoni-VT Partner Block -->
      <div class="bg-surface-card border border-border rounded-2xl p-8 md:p-10 max-w-[800px] mx-auto text-center">
        <p class="text-primary-light/70 text-xs font-semibold uppercase tracking-widest mb-4">Unser Technik-Partner: Dosoni-VT</p>
        <img src="https://www.dropzone-band.de/wp-content/uploads/2024/02/dosoni-vt-logo_x2-300x50-3.png" alt="Dosoni-VT Logo" class="h-16 mx-auto mb-6 object-contain" loading="lazy" />
        <p class="text-white/60 leading-relaxed mb-6">Wir arbeiten mit dem Veranstaltungstechnik-Dienstleister DOSONI-VT aus Remseck am Neckar zusammen.</p>
        <blockquote class="border-l-2 border-primary/40 pl-5 text-left">
          <p class="text-white/70 italic leading-relaxed mb-3">„Ihr Unternehmen, Ihre Veranstaltung und Ihre Gäste sind für uns das Wichtigste: Wir engagieren uns persönlich dafür, dass Ihr Event technisch perfekt und sicher abläuft. Und dafür, dass Sie und Ihre Besucher und Teilnehmer begeistert sind. Die passende Veranstaltungstechnik ist für uns dabei ein wichtiges Mittel zum Zweck."</p>
          <footer class="text-white/50 text-sm">Patrick Fischer, Geschäftsführer</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="py-24 md:py-32 bg-surface">
    <div class="text-center">
      <a href="/booking/" class="btn btn-primary">Festival-Booking anfragen</a>
    </div>
  </section>

</BaseLayout>

<script>
  // Festival Carousel with Thumbs + Lightbox
  (() => {
    const track = document.getElementById('festivalTrack');
    const carousel = document.getElementById('festivalCarousel');
    const prevBtn = document.getElementById('festivalPrev');
    const nextBtn = document.getElementById('festivalNext');
    const thumbsContainer = document.getElementById('festivalThumbs');
    if (!track || !thumbsContainer) return;

    const total = track.children.length;
    const thumbs = thumbsContainer.querySelectorAll('button');
    let pos = 0;
    let autoTimer: ReturnType<typeof setInterval>;

    // Collect image sources for lightbox
    const images = Array.from(track.querySelectorAll('img')).map(img => ({
      src: (img as HTMLImageElement).src,
      alt: (img as HTMLImageElement).alt,
    }));

    function go(i: number) {
      pos = ((i % total) + total) % total;
      track.style.transform = `translateX(-${pos * 100}%)`;
      updateThumbs();
    }

    function updateThumbs() {
      thumbs.forEach((t, i) => {
        if (i === pos) {
          t.classList.add('border-primary');
          t.classList.remove('border-transparent', 'opacity-50');
        } else {
          t.classList.remove('border-primary');
          t.classList.add('border-transparent', 'opacity-50');
        }
      });
    }

    thumbs.forEach(t => {
      t.addEventListener('click', () => {
        go(Number(t.getAttribute('data-thumb')));
        resetAuto();
      });
    });

    prevBtn?.addEventListener('click', () => { go(pos - 1); resetAuto(); });
    nextBtn?.addEventListener('click', () => { go(pos + 1); resetAuto(); });

    let sx = 0;
    track.addEventListener('touchstart', (e) => { sx = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      const diff = sx - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) { go(pos + (diff > 0 ? 1 : -1)); resetAuto(); }
    });

    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => go(pos + 1), 5000);
    }

    go(0);
    resetAuto();

    // Lightbox
    const lb = document.getElementById('festivalLightbox');
    const lbImg = document.getElementById('festivalLbImage') as HTMLImageElement;
    const lbClose = document.getElementById('festivalLbClose');
    const lbPrev = document.getElementById('festivalLbPrev');
    const lbNext = document.getElementById('festivalLbNext');
    if (!lb || !lbImg) return;

    let lbPos = 0;

    function lbShow(i: number) {
      lbPos = ((i % total) + total) % total;
      lbImg.src = images[lbPos].src;
      lbImg.alt = images[lbPos].alt;
      lb.classList.remove('hidden');
      lb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function lbHide() {
      lb.classList.add('hidden');
      lb.classList.remove('flex');
      document.body.style.overflow = '';
    }

    // Click on main image opens lightbox
    carousel?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('button')) return; // ignore arrow clicks
      lbShow(pos);
    });

    lbClose?.addEventListener('click', lbHide);
    lbPrev?.addEventListener('click', () => lbShow(lbPos - 1));
    lbNext?.addEventListener('click', () => lbShow(lbPos + 1));

    lb.addEventListener('click', (e) => {
      if (e.target === lb) lbHide();
    });

    document.addEventListener('keydown', (e) => {
      if (lb.classList.contains('hidden')) return;
      if (e.key === 'Escape') lbHide();
      if (e.key === 'ArrowLeft') lbShow(lbPos - 1);
      if (e.key === 'ArrowRight') lbShow(lbPos + 1);
    });
  })();
</script>
