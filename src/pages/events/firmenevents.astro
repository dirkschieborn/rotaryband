---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

---

<BaseLayout title="Band für Firmenevents – Dropzone" description="Professionelle Live-Band für Firmenevents, Galas und Business-Veranstaltungen. Dropzone – Coverband aus Stuttgart.">

  <Hero
    title="Firmenevents"
    subtitle="Wir machen euer Corporate zum Event."
    cta={{ label: 'Jetzt anfragen', href: '/booking/' }}
    ctaSecondary={{ label: 'Kostenrechner', href: '/kostenrechner/' }}
    backgroundImage="https://www.dropzone-band.de/wp-content/uploads/2024/02/11034_Mercedes-Benz-Tech-Motion_Schrittmacher_FotografieEbinger_JPEG_Webresolution_1920Pix__852_5263.jpg"
    backgroundPosition="center 5%"
  />

  <!-- ============ GET BOOSTED ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(130, 60, 220, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Get boosted!</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Musik, die <span class="text-primary-light">beeindruckt</span></h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Feiert euer Firmenjubiläum, startet mit Schwung in ein neues Geschäftsjahr beim Kick-Off-Event oder verbreitet festliche Stimmung bei eurer Weihnachtsfeier – wir liefern den maßgeschneiderten Live-Soundtrack für jeden Anlass.
          </p>
          <p class="text-white/50 leading-relaxed mb-4">
            Mit passenden Rundum-Sorglos-Paketen inklusive professioneller Licht- und Soundtechnik und einem vielseitigen Repertoire schaffen wir unvergessliche Momente für eure Firmenevents.
          </p>
          <p class="text-white/50 leading-relaxed mb-8">
            Ihr wollt mehr wissen? Hier haben wir einige Punkte zusammengestellt, die ihr beachten solltet, wenn ihr eine <a href="/bands-fuer-firmenfeiern-buchen/" class="text-primary-light hover:underline">Band für eure Firmenfeier bucht</a>.
          </p>
          <a href="/booking/" class="btn btn-outline text-sm !py-2.5 !px-5">Jetzt anfragen</a>
        </div>
        <div>
          {/* Main image */}
          <div class="relative overflow-hidden rounded-2xl shadow-2xl cursor-zoom-in" id="firmenCarousel">
            <div class="flex transition-transform duration-700 ease-out" id="firmenTrack">
              {[
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2023/11/test-1.jpg', alt: 'Dropzone auf Firmenevent' },
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/Suedpack_Tag2_109.jpg', alt: 'Dropzone Live Firmenevent' },
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/DSC_2332-scaled.jpg', alt: 'Dropzone Firmenfeier' },
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2023/09/DZ.016.6990.jpg', alt: 'Dropzone Live Performance' },
                { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/Suedpack_Tag2_158.jpg', alt: 'Dropzone Firmenevent Bühne' },
              ].map((img) => (
                <div class="w-full flex-shrink-0">
                  <img src={img.src} alt={img.alt} class="w-full aspect-[16/9] object-cover" loading="lazy" />
                </div>
              ))}
            </div>
            <button id="firmenPrev" class="absolute top-1/2 left-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Vorheriges Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button id="firmenNext" class="absolute top-1/2 right-3 -translate-y-1/2 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm flex items-center justify-center text-white/80 hover:text-white hover:bg-black/60 transition-all cursor-pointer z-10" aria-label="Nächstes Bild">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
          {/* Thumbs */}
          <div class="flex gap-2 mt-3" id="firmenThumbs">
            {[
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2023/11/test-1.jpg', alt: 'Dropzone auf Firmenevent' },
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/Suedpack_Tag2_109.jpg', alt: 'Dropzone Live Firmenevent' },
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/DSC_2332-scaled.jpg', alt: 'Dropzone Firmenfeier' },
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2023/09/DZ.016.6990.jpg', alt: 'Dropzone Live Performance' },
              { src: 'https://www.dropzone-band.de/wp-content/uploads/2024/02/Suedpack_Tag2_158.jpg', alt: 'Dropzone Firmenevent Bühne' },
            ].map((img, i) => (
              <button class={`flex-1 rounded-lg overflow-hidden border-2 transition-all duration-300 cursor-pointer ${i === 0 ? 'border-primary' : 'border-transparent opacity-50 hover:opacity-80'}`} data-thumb={i}>
                <img src={img.src} alt={img.alt} class="w-full aspect-[16/9] object-cover" loading="lazy" />
              </button>
            ))}
          </div>

          {/* Carousel Lightbox */}
          <div id="firmenLightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black">
            <button id="firmenLbClose" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Schließen">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
            <button id="firmenLbPrev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Zurück">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button id="firmenLbNext" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer z-10" aria-label="Weiter">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <img id="firmenLbImage" src="" alt="" class="max-w-[95vw] max-h-[95vh] object-contain" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ REFERENZEN ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 30% 50%, rgba(200, 150, 40, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Referenzen? Na klar!</p>
        <h2 class="text-4xl md:text-5xl font-bold">Das sagen Firmenkunden<br/>über uns.</h2>
      </div>

      <!-- Carousel -->
      <div class="relative">
        <div class="overflow-hidden" id="refCarousel">
          <div class="flex transition-transform duration-500 ease-out" id="refTrack">
            {[
              { text: 'Es ist euch gelungen, einen maßgeschneiderten Mix aus stilvoller Loungemusik und tanzbaren Partygrooves zu schaffen, der – gepaart mit der unterhaltsamen und gewitzten Moderation eures Frontmanns Jean-Pierre – zu dem vollen Erfolg der Veranstaltung maßgeblich beigetragen hat.', logo: '/images/logos/bayernlb.png', company: 'Bayern LB', type: 'Firmenevent' },
              { text: 'Für Veranstalter ist Dropzone das perfekte Rundum-Sorglos-Paket: Sie buchen, die spielen, das Publikum hat Spaß.', logo: '/images/logos/motorpresse.jpg', company: 'Motor Presse Stuttgart', type: 'Firmenfeier' },
              { text: 'WOW!!! Wie ihr es, nahezu mühelos, geschafft habt, die ca. 900 Gäste auf die Beine und die Tanzfläche zu bewegen, verdient großen Applaus, den ihr natürlich auch schon während unserer Veranstaltung immer wieder bekommen habt.', logo: '/images/logos/nintendo.jpg', company: 'Nintendo Europe GmbH', type: 'Firmenevent', logoZoom: true },
              { text: 'Die Professionalität, mit der ihr die Anforderungen zu Musikauswahl und Logistik erfüllt habt, hat mich sehr beeindruckt. Das Können und das Engagement jedes Bandmitglieds sowie das breitgefächerte Repertoire waren die Garanten für einen gelungenen Abend.', logo: '/images/logos/telekom-round.jpg', company: 'Deutsche Telekom', type: 'Firmenevent', logoZoom: true },
              { text: 'Wir möchten uns auf diesem Weg ganz herzlich bei euch für die professionelle Zusammenarbeit und für die sehr gelungene musikalische Untermalung an diesem Abend bedanken.', logo: '/images/logos/messe-stuttgart.jpg', company: 'Landesmesse Stuttgart GmbH', type: 'Jubiläumsfeier', logoZoom: true },
              { text: 'Ob zu Anfang etwas mehr Power, zum Abendessen dezente Hintergrundmusik oder später für die Tanzbegeisterten unter unseren Gästen – ihr habt immer den richtigen Ton getroffen.', logo: '/images/logos/mercedes-benz.jpg', company: 'Mercedes-Benz', type: 'Firmenevent' },
              { text: 'Nochmals vielen herzlichen Dank für den fantastischen Auftritt auf den CHIP FOTO AWARDS. Ihr habt für eine top Stimmung im Saal gesorgt und unsere Gäste bestens unterhalten.', logo: '/images/logos/chip.jpg', company: 'CHIP Communications GmbH', type: 'Firmenevent' },
              { text: 'Euer professioneller Auftritt und die tolle Stimmung, die ihr erzeugt habt, haben einen wesentlichen Teil zum Gelingen des Fests beigetragen. Ihr habt wirklich gerockt!', logo: '/images/logos/mhp.png', company: 'MHP Management- und IT-Beratung', type: 'Firmenevent' },
            ].map((item) => (
              <div class="ref-slide flex-shrink-0 px-3">
                <div class="bg-surface-card border border-border rounded-2xl p-6 md:p-8 flex flex-col h-full">
                  <div class="flex items-center gap-4 pb-5 mb-5 border-b border-border">
                    <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center flex-shrink-0 overflow-hidden">
                      <img src={item.logo} alt={item.company} class:list={[item.logoZoom ? 'w-full h-full object-cover' : 'w-10 h-10 object-contain']} />
                    </div>
                    <div>
                      <p class="text-white font-semibold text-sm">{item.company}</p>
                      <p class="text-muted text-xs">{item.type}</p>
                    </div>
                  </div>
                  <svg class="w-8 h-8 text-primary/40 mb-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                  <p class="text-white/70 italic leading-relaxed flex-1">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Navigation Arrows -->
        <button id="refPrev" class="absolute top-1/2 -left-5 -translate-y-1/2 w-10 h-10 rounded-full bg-surface-card border border-border flex items-center justify-center text-white/60 hover:text-white hover:border-primary/50 transition-all z-10 cursor-pointer hidden md:flex" aria-label="Zurück">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button id="refNext" class="absolute top-1/2 -right-5 -translate-y-1/2 w-10 h-10 rounded-full bg-surface-card border border-border flex items-center justify-center text-white/60 hover:text-white hover:border-primary/50 transition-all z-10 cursor-pointer hidden md:flex" aria-label="Weiter">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        <!-- Dots -->
        <div class="flex justify-center gap-2 mt-8" id="refDots"></div>
      </div>

    </div>
  </section>

  <!-- ============ INTERVIEW ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 65% 50%, rgba(40, 180, 130, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[3fr_2fr] gap-12 md:gap-16 items-center">
        <div>
          <div class="video-wrapper !rounded-2xl shadow-2xl overflow-hidden">
            <iframe src="https://www.youtube.com/embed/zlIuCknvd30" title="Dropzone Interview – Wir begeistern Events" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          </div>
        </div>
        <div>
          <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Wir begeistern Events</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">„Drei, vier, Vollgas!"</h2>
          <p class="text-white/60 leading-relaxed mb-4">
            Lernt uns kennen: Sarah und Jean-Pierre, unsere beiden Frontsänger. Im Interview informieren sie euch über unser Selbstverständnis als Live-Band, die Songauswahl, die Bedeutung langjähriger Bühnenerfahrung, die verschiedenen Besetzungsvarianten und unser Motto „Wir begeistern Events".
          </p>
          <p class="text-white/50 leading-relaxed">
            Und sollten Fragen offenbleiben, wir sind bei jeglichen Fragen rund um euer Event jederzeit für euch da. Wir freuen uns, von euch zu hören!
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SHOWREELS ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 35% 50%, rgba(180, 50, 100, 0.16) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Firmenevents in Aktion</p>
        <h2 class="text-4xl md:text-5xl font-bold">Showreels</h2>
      </div>
      <div class="max-w-[800px] mx-auto">
        <div class="video-wrapper !rounded-2xl shadow-xl overflow-hidden">
          <iframe src="https://www.youtube.com/embed/ctPncWWIwvU" title="Showreel Firmenevent" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BAND-PAKETE ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 35% at 50% 50%, rgba(40, 200, 200, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Flexibel buchbar</p>
        <h2 class="text-4xl md:text-5xl font-bold">Band-Pakete</h2>
        <p class="text-white/50 mt-4 max-w-[700px] mx-auto">Ob loungiges Get Together, Firmenevent im Club Style oder die ganz große Bühne: Wir haben eingespielte Top-Besetzungen am Start. Vom Trio bis zum Festival-Line-Up.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-5 relative z-10">
        {[
          { title: 'Small', label: 'Kleine Besetzung', image: 'https://www.dropzone-band.de/wp-content/uploads/2015/09/DSC02444.jpg', desc: 'Duo bis Quartett für Lounges, Sektempfänge und kleine, feine Anlässe. Auf Wunsch mit Licht- und Tontechnik.' },
          { title: 'Medium', label: 'Mittlere Besetzung', badge: 'Top Seller', image: 'https://www.dropzone-band.de/wp-content/uploads/2019/02/DSC02439.jpg', desc: 'Unsere 5- bis 6-köpfige Standardbesetzung für Firmenjubiläen, Sommerfeste, Weihnachtsfeiern und Kick-Off-Events. Echtes Live-Club-Feeling.' },
          { title: 'Big', label: 'Große Besetzung', image: 'https://www.dropzone-band.de/wp-content/uploads/2024/01/Unbenannt-1-1.jpg', desc: 'Das große Line-Up für Open Airs und Firmenjubiläen mit großer Bühne. Mit Bläser-Section, Percussion, Background-Vocals und mehr.' },
        ].map((pkg) => (
          <div class="bg-surface-card border border-border rounded-2xl overflow-hidden hover:border-primary/30 transition-all duration-300">
            {pkg.image && <img src={pkg.image} alt={pkg.title} class="w-full aspect-[4/3] object-cover block" loading="lazy" />}
            <div class="p-6">
              <p class="text-primary-light/70 text-xs font-semibold uppercase tracking-widest mb-2">{pkg.label}</p>
              <div class="flex items-center gap-3 mb-3">
                <h3 class="text-white font-bold text-2xl font-[Rubik]">{pkg.title}</h3>
                {pkg.badge && <span class="px-3 py-1 bg-primary/15 text-primary-light rounded-full text-xs font-semibold">{pkg.badge}</span>}
              </div>
              <p class="text-white/50 leading-relaxed text-sm">{pkg.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ ADD-ON-PAKETE (unter Band-Pakete) ============ -->
  <section class="pb-24 md:pb-32 -mt-12 bg-surface relative overflow-hidden">
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-2 gap-5">
        {[
          { title: 'DJ-Service', desc: 'Live-Band und professioneller DJ – die bewährte Kombination. Background-Sound im Vorfeld, Partymusik in den Spielpausen und nahtloser Übergang nach dem Live-Act.' },
          { title: 'Show Acts', desc: 'Magier, Walking Acts, Tänzer, Akrobaten, Comedians: Wir empfehlen euch Show-Act-Highlights, die wir in 20 Jahren Bühnenerfahrung kennengelernt haben.' },
        ].map((item) => (
          <div class="bg-surface-card border border-border rounded-2xl p-6 hover:border-primary/30 transition-all duration-300">
            <p class="text-primary-light/70 text-xs font-semibold uppercase tracking-widest mb-2">Add-On-Paket</p>
            <h3 class="text-white font-bold text-xl font-[Rubik] mb-3">{item.title}</h3>
            <p class="text-white/50 leading-relaxed text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TECHNIK-PAKETE ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 50% 50%, rgba(80, 80, 180, 0.12) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="text-center mb-16">
        <p class="text-primary-light font-semibold text-sm uppercase tracking-widest mb-3">Licht. Ton. Leidenschaft.</p>
        <h2 class="text-4xl md:text-5xl font-bold">Technik-Pakete</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-5 mb-16">
        {[
          { title: 'Technik Small', desc: 'Maßgeschneiderte Veranstaltungstechnik und Tontechniker für die kleine Bandformation. Perfekte optische und akustische Inszenierung.' },
          { title: 'Technik Medium', badge: 'Top Seller', desc: 'Veranstaltungstechnik und Tontechniker für unsere mittlere Besetzung. Damit jede Nuance bei den Ohren und Tanzbeinen eurer Gäste ankommt.' },
          { title: 'Technik Big', desc: 'State-of-the-Art-Equipment für die große Bühne. Komplette Location mit Klang und Licht versorgt. Auf Wunsch mit Bühnen- und Traversenaufbauten.' },
        ].map((item) => (
          <div class="bg-surface-card border border-border rounded-2xl p-6 hover:border-primary/30 transition-all duration-300">
            <div class="flex items-center gap-3 mb-3">
              <h3 class="text-white font-bold text-lg font-[Rubik]">{item.title}</h3>
              {item.badge && <span class="px-3 py-1 bg-primary/15 text-primary-light rounded-full text-xs font-semibold">{item.badge}</span>}
            </div>
            <p class="text-white/50 leading-relaxed text-sm">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- Dosoni-VT Partner Block -->
      <div class="bg-surface-card border border-border rounded-2xl p-8 md:p-10 max-w-[800px] mx-auto text-center">
        <p class="text-primary-light/70 text-xs font-semibold uppercase tracking-widest mb-4">Unser Technik-Partner: Dosoni-VT</p>
        <img src="https://www.dropzone-band.de/wp-content/uploads/2024/02/dosoni-vt-logo_x2-300x50-3.png" alt="Dosoni-VT Logo" class="h-16 mx-auto mb-6 object-contain" loading="lazy" />
        <p class="text-white/60 leading-relaxed mb-6">Wir arbeiten mit dem Veranstaltungstechnik-Dienstleister DOSONI-VT aus Remseck am Neckar zusammen.</p>
        <blockquote class="border-l-2 border-primary/40 pl-5 text-left">
          <p class="text-white/70 italic leading-relaxed mb-3">„Ihr Unternehmen, Ihre Veranstaltung und Ihre Gäste sind für uns das Wichtigste: Wir engagieren uns persönlich dafür, dass Ihr Event technisch perfekt und sicher abläuft. Und dafür, dass Sie und Ihre Besucher und Teilnehmer begeistert sind. Die passende Veranstaltungstechnik ist für uns dabei ein wichtiges Mittel zum Zweck."</p>
          <footer class="text-white/50 text-sm">Patrick Fischer, Geschäftsführer</footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ============ SPECIAL SHOWS ============ -->
  <section class="py-24 md:py-32 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 45% 35% at 70% 50%, rgba(220, 140, 40, 0.14) 0%, transparent 100%);"></div>
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="grid md:grid-cols-[2fr_3fr] gap-12 md:gap-16 items-center">
        <div>
          <span class="inline-block px-4 py-1.5 bg-primary/15 text-primary-light rounded-full text-sm font-semibold mb-6">Special Guests</span>
          <h2 class="text-3xl md:text-4xl font-bold mb-6 leading-tight">Special Shows</h2>
