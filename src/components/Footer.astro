<style>
  /* CTA Buttons */
  .cta-btn-primary,
  .cta-btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.8rem;
    border-radius: 12px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
    min-width: 200px;
  }

  .cta-btn-primary {
    background: #fff;
    color: #ac4839;
  }
  .cta-btn-primary:hover {
    background: #f0f0f0;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
  }

  .cta-btn-outline {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.5);
  }
  .cta-btn-outline:hover {
    border-color: #fff;
    background: rgba(255,255,255,0.1);
    transform: translateY(-2px);
  }

  /* Footer */
  .site-footer {
    background: #0d0b14;
    padding: 0;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 2rem 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1.4fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }

  /* Brand column */
  .footer-tagline {
    color: rgba(255,255,255,0.4);
    font-size: 0.88rem;
    margin-top: 1.2rem;
    line-height: 1.7;
    max-width: 280px;
  }

  .footer-social-row {
    display: flex;
    gap: 0.6rem;
    margin-top: 1.5rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.4);
    transition: all 0.25s ease;
  }
  .social-icon:hover {
    color: #fff;
    background: #ac4839;
    transform: translateY(-2px);
  }

  /* Contact column */
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    font-size: 0.92rem;
    transition: color 0.2s ease;
  }
  .contact-row:hover {
    color: #fff;
  }
  .contact-row:hover .contact-icon {
    background: #ac4839;
    color: #fff;
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    color: #c95a4a;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .contact-icon--wa {
    color: #25d366;
  }

  /* Nav columns */
  .footer-heading {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 1.2rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.55rem;
  }

  .footer-links a {
    color: rgba(255,255,255,0.4);
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .footer-links a:hover {
    color: #fff;
    padding-left: 3px;
  }

  /* Bottom bar */
  .footer-bar {
    margin-top: 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center;
  }
  .footer-bar p {
    color: rgba(255,255,255,0.25);
    font-size: 0.82rem;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .contact-list {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 500px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
    .cta-btn-primary,
    .cta-btn-outline {
      min-width: 160px;
      padding: 0.9rem 2rem;
    }
  }
</style>
