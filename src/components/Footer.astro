---
const currentYear = new Date().getFullYear();
---

<!-- CTA Banner -->
<section style="position:relative;overflow:hidden;min-height:420px;display:flex;align-items:center;justify-content:center;">
  <video autoplay muted loop playsinline style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;">
    <source src="/images/wp/2024-09-Dropzoneband_2024_final_v1_HD_1.mp4" type="video/mp4" />
  </video>
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(124,58,237,0.88),rgba(91,33,182,0.92),rgba(124,58,237,0.85));z-index:1;"></div>
  <div style="position:relative;z-index:2;text-align:center;padding:3rem 1.5rem;max-width:700px;">
    <h2 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3.2rem);font-weight:800;color:#fff;line-height:1.15;margin-bottom:1rem;">Bereit für unvergessliche Musik?</h2>
    <p style="color:rgba(255,255,255,0.85);font-size:1.1rem;margin-bottom:2.5rem;">Erzählt uns von eurem Event – wir freuen uns auf eure Anfrage.</p>
    <div style="display:flex;gap:1.2rem;justify-content:center;flex-wrap:wrap;">
      <a href="/booking/" class="cta-btn-primary">Jetzt anfragen</a>
      <a href="/kostenrechner/" class="cta-btn-outline">Kostenrechner</a>
    </div>
  </div>
</section>

