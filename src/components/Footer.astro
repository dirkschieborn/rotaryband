---
const currentYear = new Date().getFullYear();
---

<!-- Footer -->
<footer class="site-footer">
  <div class="footer-inner">
    <!-- Row 1: Logo + Nav columns -->
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <img src="/images/logo_weiss.png" alt="2R2B – Die Rotary Band" style="height:48px;width:auto;display:block;" />
        <p class="footer-tagline">Die Live-Band des Rotary Club Stuttgart-Remstal.</p>
        <div class="footer-social-row">
          <a href="https://www.instagram.com/dierotaryband" target="_blank" rel="noopener" aria-label="Instagram" class="social-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Kontakt -->
      <div class="footer-col">
        <h4 class="footer-heading">Kontakt</h4>
        <div class="contact-list">
          <a href="tel:+491738583938" class="contact-row">
            <span class="contact-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            </span>
            <span>+49 173 8583938</span>
          </a>
          <a href="mailto:info@dierotaryband.de" class="contact-row">
            <span class="contact-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            </span>
            <span>info@dierotaryband.de</span>
          </a>
        </div>
      </div>

      <!-- Rechtliches -->
      <div class="footer-col">
        <h4 class="footer-heading">Rechtliches</h4>
        <ul class="footer-links">
          <li><a href="/impressum/">Impressum</a></li>
          <li><a href="/datenschutz/">Datenschutz</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bar">
      <p>&copy; 2026 Rotary Band GbR. Alle Rechte vorbehalten.</p>
    </div>
  </div>
</footer>

<style>
  /* CTA Buttons */
  .cta-btn-primary,
  .cta-btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.8rem;
    border-radius: 12px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.25s ease;
    min-width: 200px;
  }

  .cta-btn-primary {
    background: #fff;
    color: #ac4839;
  }
  .cta-btn-primary:hover {
    background: #f0f0f0;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
  }

  .cta-btn-outline {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.5);
  }
  .cta-btn-outline:hover {
    border-color: #fff;
    background: rgba(255,255,255,0.1);
    transform: translateY(-2px);
  }

  /* Footer */
  .site-footer {
    background: var(--color-surface);
    padding: 0;
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 2rem 0;
  }

  .footer-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    text-align: center;
  }

  /* Brand column */
  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .footer-brand img {
    margin: 0 auto;
  }

  .footer-tagline {
    color: rgba(255,255,255,0.4);
    font-size: 0.88rem;
    margin-top: 1.2rem;
    line-height: 1.7;
    max-width: 280px;
  }

  .footer-social-row {
    display: flex;
    gap: 0.6rem;
    margin-top: 1.5rem;
    justify-content: center;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.4);
    transition: all 0.25s ease;
  }
  .social-icon:hover {
    color: #fff;
    background: #ac4839;
    transform: translateY(-2px);
  }

  /* Contact column */
  .footer-col {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    font-size: 0.92rem;
    transition: color 0.2s ease;
  }
  .contact-row:hover {
    color: #fff;
  }
  .contact-row:hover .contact-icon {
    background: #ac4839;
    color: #fff;
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    color: #c95a4a;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .contact-icon--wa {
    color: #25d366;
  }

  /* Nav columns */
  .footer-heading {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 1.2rem;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.55rem;
  }

  .footer-links a {
    color: rgba(255,255,255,0.4);
    font-size: 0.9rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .footer-links a:hover {
    color: #fff;
    padding-left: 3px;
  }

  /* Bottom bar */
  .footer-bar {
    margin-top: 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.06);
    text-align: center;
  }
  .footer-bar p {
    color: rgba(255,255,255,0.25);
    font-size: 0.82rem;
    margin: 0;
  }

  .footer-links {
    text-align: center;
  }
</style>
