---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  schema?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description = 'Die Rotary Band – Live-Musik für Benefizveranstaltungen, Firmenevents und private Feiern.',
  image = '/images/og-image.jpg',
  schema,
} = Astro.props;

const siteUrl = 'https://www.dierotaryband.de';
const canonicalURL = new URL(Astro.url.pathname, Astro.site || siteUrl);
const absoluteImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

// Base Organization schema – always present
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': ['MusicGroup', 'LocalBusiness'],
  '@id': `${siteUrl}/#organization`,
  name: 'Die Rotary Band',
  alternateName: 'Die Rotary Band',
  description: 'Die Rotary Band – Live-Band des Rotary Club Stuttgart-Remstal. Rock\'n\'Roll Klassiker für den guten Zweck. 100% der Gage gehen an die Kinderstiftung Funke.',
  url: siteUrl,
  logo: `${siteUrl}/images/logo_weiss.png`,
  image: `${siteUrl}/images/rotaryband-hero.webp`,
  telephone: '+491738583938',
  email: 'info@dierotaryband.de',
  foundingDate: '2015',
  genre: ['Rock', 'Pop', 'Soul', 'Party'],
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Einsteinstr. 45',
    addressLocality: 'Leonberg',
    postalCode: '71229',
    addressCountry: 'DE',
    addressRegion: 'Baden-Württemberg',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 48.6778,
    longitude: 8.8731,
  },
  areaServed: [
    { '@type': 'Country', name: 'Deutschland' },
    { '@type': 'Country', name: 'Schweiz' },
    { '@type': 'Country', name: 'Österreich' },
  ],
  sameAs: [
    'https://www.instagram.com/dierotaryband',
  ],
  member: [
    { '@type': 'Person', name: 'Eckhard Burling', roleName: 'Guitar, Vocals & Ukulele' },
    { '@type': 'Person', name: 'Rainer Grosse', roleName: 'Bass & Vocals' },
    { '@type': 'Person', name: 'Oliver Boese', roleName: 'Saxophone, Vocals & Percussion' },
    { '@type': 'Person', name: 'Dirk Schieborn', roleName: 'Keys & Cello' },
    { '@type': 'Person', name: 'Carl-Philipp Clarenbach', roleName: 'Drums & Cajón' },
  ],
  numberOfEmployees: { '@type': 'QuantitativeValue', value: 5 },
  knowsAbout: ['Live-Musik', 'Benefizveranstaltungen', 'Charity Events', 'Eventband', 'Rock\'n\'Roll'],
};

// WebSite schema for sitelinks search
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  name: 'Die Rotary Band',
  url: siteUrl,
  publisher: { '@id': `${siteUrl}/#organization` },
  inLanguage: 'de-DE',
};

// Collect all schemas
const allSchemas = [organizationSchema, websiteSchema, ...(Array.isArray(schema) ? schema : schema ? [schema] : [])];
---

<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title === 'Die Rotary Band' ? title : `${title} | Die Rotary Band`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title === 'Die Rotary Band' ? title : `${title} | Die Rotary Band`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Die Rotary Band" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Die Rotary Band`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon-32x32.webp" sizes="32x32" type="image/webp" />
    <link rel="icon" href="/favicon-192x192.webp" sizes="192x192" type="image/webp" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.webp" />

    <!-- Schema.org JSON-LD -->
    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  main {
    margin-top: var(--header-height);
  }
</style>
